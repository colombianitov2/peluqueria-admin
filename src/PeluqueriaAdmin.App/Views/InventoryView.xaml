<UserControl x:Class="PeluqueriaAdmin.App.Views.InventoryView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels" d:DataContext="{d:DesignInstance Type=viewModels:InventoryViewModel, IsDesignTimeCreatable=False}"
 d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Margin" Value="0,0,0,5" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#273449" /></Style>
    <Style x:Key="FieldBox" TargetType="Control"><Setter Property="MinHeight" Value="36" /><Setter Property="Padding" Value="9,6" /></Style>
    <Style x:Key="WrappingColumnHeader" TargetType="DataGridColumnHeader"><Setter Property="VerticalContentAlignment" Value="Center" /><Setter Property="ContentTemplate"><Setter.Value><DataTemplate><TextBlock Text="{Binding}" TextWrapping="Wrap" /></DataTemplate></Setter.Value></Setter></Style>
  </UserControl.Resources>
  <Grid Background="#F5F7FA">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
    <ScrollViewer Grid.Row="0" MaxHeight="415" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="26,26,26,12">
        <DockPanel Margin="0,0,0,14"><StackPanel DockPanel.Dock="Right" MinWidth="190"><TextBlock HorizontalAlignment="Right" Style="{StaticResource FieldLabel}" Text="Periodo a mostrar" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" /><WrapPanel Margin="0,6,0,0" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}"><DatePicker Width="135" Margin="0,0,6,0" SelectedDate="{Binding CustomPeriodFrom}" /><DatePicker Width="135" SelectedDate="{Binding CustomPeriodThrough}" /></WrapPanel></StackPanel><StackPanel><TextBlock FontSize="28" FontWeight="SemiBold" Text="Inventario" /><TextBlock Margin="0,5,0,0" Foreground="#5B6575" Text="Existencias actuales, movimientos y planes de reposición se muestran por separado." /></StackPanel></DockPanel>
        <Border Padding="16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <StackPanel>
            <WrapPanel Margin="0,0,0,12"><TextBlock Margin="0,8,10,0" Style="{StaticResource FieldLabel}" Text="Acción" /><ComboBox Width="250" Style="{StaticResource FieldBox}" ItemsSource="{Binding Editor.ActionOptions}" SelectedItem="{Binding Editor.SelectedAction}" /></WrapPanel>
            <WrapPanel DataContext="{Binding Editor}">
              <StackPanel Width="235" Margin="0,0,14,12" Visibility="{Binding ShowPrimary, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="{Binding PrimaryLabel}" /><TextBox Text="{Binding PrimaryText, UpdateSourceTrigger=PropertyChanged}"><TextBox.Style><Style TargetType="TextBox" BasedOn="{StaticResource FieldBox}"><Style.Triggers><DataTrigger Binding="{Binding UsePrimarySelector}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers></Style></TextBox.Style></TextBox><ComboBox DisplayMemberPath="Display" ItemsSource="{Binding EntityOptions}" SelectedItem="{Binding SelectedEntityOption}"><ComboBox.Style><Style TargetType="ComboBox" BasedOn="{StaticResource FieldBox}"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding UsePrimarySelector}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></ComboBox.Style></ComboBox></StackPanel>
              <StackPanel Width="220" Margin="0,0,14,12" Visibility="{Binding ShowSecondary, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="{Binding SecondaryLabel}" /><ComboBox Style="{StaticResource FieldBox}" IsEditable="True" ItemsSource="{Binding SecondaryOptions}" Text="{Binding SecondaryText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="190" Margin="0,0,14,12" Visibility="{Binding ShowExtra, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="{Binding ExtraLabel}" /><ComboBox Style="{StaticResource FieldBox}" IsEditable="True" ItemsSource="{Binding ExtraOptions}" Text="{Binding ExtraText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="175" Margin="0,0,14,12" Visibility="{Binding ShowDate, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="{Binding DateLabel}" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding FormDate}" /></StackPanel>
              <StackPanel Width="190" Margin="0,0,14,12" Visibility="{Binding ShowAmount, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="{Binding AmountLabel}" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="190" Margin="0,0,14,12" Visibility="{Binding ShowSecondaryAmount, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="{Binding SecondaryAmountLabel}" TextWrapping="Wrap" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding SecondaryAmountText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="170" Margin="0,0,14,12" Visibility="{Binding ShowQuantity, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="{Binding QuantityLabel}" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="245" Margin="0,0,14,12" Visibility="{Binding ShowOptionalDescription, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox MinHeight="55" Padding="9,6" TextWrapping="Wrap" Text="{Binding OptionalDescriptionText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            </WrapPanel>
            <WrapPanel><Button Margin="0,0,9,8" Padding="15,8" Background="#2E5BFF" Foreground="White" Command="{Binding SaveCommand}" Content="Guardar operación" /><Button Margin="0,0,9,8" Padding="13,8" Command="{Binding LoadSelectedCommand}" Content="Editar selección" /><Button Margin="0,0,9,8" Padding="13,8" Command="{Binding SaveEditCommand}" Content="Guardar edición" /><CheckBox Margin="10,0,8,8" VerticalAlignment="Center" IsChecked="{Binding Editor.ConfirmDelete}" Content="Confirmo eliminar" /><Button Margin="0,0,0,8" Padding="13,8" Command="{Binding DeleteCommand}" Content="Eliminar selección" /></WrapPanel>
            <TextBlock Margin="0,5,0,0" Foreground="#0F766E" Text="{Binding Editor.StatusMessage}" TextWrapping="Wrap" /><TextBlock Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
    <TabControl Grid.Row="1" Margin="26,0,26,26">
      <TabItem Header="Inventario actual">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding CurrentInventory}" SelectedItem="{Binding SelectedCurrentRow}" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ColumnHeaderStyle="{StaticResource WrappingColumnHeader}" HorizontalScrollBarVisibility="Auto">
          <DataGrid.Columns><DataGridTextColumn Width="160" Binding="{Binding Name}" Header="Producto" /><DataGridTextColumn Width="180" Binding="{Binding Category}" Header="Categoría" /><DataGridTextColumn Width="105" Binding="{Binding CurrentQuantity}" Header="Cantidad actual" /><DataGridTextColumn Width="145" Binding="{Binding AverageUnitCost}" Header="Costo unitario promedio" /><DataGridTextColumn Width="145" Binding="{Binding DefaultSalePrice}" Header="Precio de venta" /><DataGridTextColumn Width="220" Binding="{Binding Description}" Header="Descripción" /><DataGridTextColumn Width="145" Binding="{Binding LastUpdate}" Header="Última actualización" /></DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="Movimientos">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding MovementHistory}" SelectedItem="{Binding SelectedMovementRow}" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ColumnHeaderStyle="{StaticResource WrappingColumnHeader}" HorizontalScrollBarVisibility="Auto">
          <DataGrid.Columns><DataGridTextColumn Width="105" Binding="{Binding Date}" Header="Fecha" /><DataGridTextColumn Width="160" Binding="{Binding Product}" Header="Producto" /><DataGridTextColumn Width="175" Binding="{Binding Type}" Header="Movimiento" /><DataGridTextColumn Width="105" Binding="{Binding QuantityIn}" Header="Cantidad que entra" /><DataGridTextColumn Width="105" Binding="{Binding QuantityOut}" Header="Cantidad que sale" /><DataGridTextColumn Width="135" Binding="{Binding UnitCost}" Header="Costo unitario" /><DataGridTextColumn Width="135" Binding="{Binding TotalValue}" Header="Valor total" /><DataGridTextColumn Width="220" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
        </DataGrid>
      </TabItem>
      <TabItem Header="Planes de reposición">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding RestockPlans}" SelectedItem="{Binding SelectedPlanRow}"><DataGrid.Columns><DataGridTextColumn Width="130" Binding="{Binding Month}" Header="Mes" /><DataGridTextColumn Width="3*" Binding="{Binding Product}" Header="Producto" /><DataGridTextColumn Width="160" Binding="{Binding NeededQuantity}" Header="Necesidad prevista" /><DataGridTextColumn Width="180" Binding="{Binding SuggestedPurchase}" Header="Compra sugerida" /></DataGrid.Columns></DataGrid>
      </TabItem>
    </TabControl>
  </Grid>
</UserControl>
