<UserControl x:Class="PeluqueriaAdmin.App.Views.LocalUseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:LocalUseViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Margin" Value="0,0,0,5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#273449" />
    </Style>
    <Style x:Key="FieldBox" TargetType="Control">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="9,6" />
    </Style>
    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="#EEF2FF" />
      <Setter Property="BorderBrush" Value="#A5B4FC" />
    </Style>
  </UserControl.Resources>

  <Grid Background="#F5F7FA">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <ScrollViewer.Style>
        <Style TargetType="ScrollViewer">
          <Setter Property="Visibility" Value="Visible" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsWorkerProfileOpen}" Value="True">
              <Setter Property="Visibility" Value="Collapsed" />
            </DataTrigger>
          </Style.Triggers>
        </Style>
      </ScrollViewer.Style>
      <StackPanel Margin="26">
        <DockPanel Margin="0,0,0,14" LastChildFill="True">
          <StackPanel DockPanel.Dock="Right" Margin="18,0,0,0" MinWidth="190">
            <TextBlock HorizontalAlignment="Right" Style="{StaticResource FieldLabel}" Text="Periodo de actividad" />
            <ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" />
            <WrapPanel Margin="0,6,0,0" HorizontalAlignment="Right"
                       Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}">
              <DatePicker Width="138" Margin="0,0,6,0" SelectedDate="{Binding CustomPeriodFrom}" />
              <DatePicker Width="138" SelectedDate="{Binding CustomPeriodThrough}" />
            </WrapPanel>
          </StackPanel>
          <StackPanel>
            <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#172033" Text="Uso del local" />
            <TextBlock Margin="0,5,0,0" Foreground="#5B6575"
                       Text="Sillas y trabajadores, periodos completos de siete días, cuotas y pagos." TextWrapping="Wrap" />
          </StackPanel>
        </DockPanel>

        <WrapPanel Margin="0,0,0,14">
          <Border Width="190" Margin="0,0,12,0" Padding="16" Background="#EFF6FF" CornerRadius="7">
            <StackPanel><TextBlock Foreground="#475569" Text="Total de sillas" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding TotalChairs}" /></StackPanel>
          </Border>
          <Border Width="190" Margin="0,0,12,0" Padding="16" Background="#F0FDF4" CornerRadius="7">
            <StackPanel><TextBlock Foreground="#475569" Text="Trabajadores vigentes" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding CurrentWorkers}" /></StackPanel>
          </Border>
          <Border Width="190" Padding="16" Background="#FFF7ED" CornerRadius="7">
            <StackPanel><TextBlock Foreground="#475569" Text="Sillas disponibles" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding AvailableChairs}" /></StackPanel>
          </Border>
        </WrapPanel>

        <TextBlock Margin="0,0,0,6" FontSize="16" FontWeight="SemiBold" Text="Actividad del periodo" />
        <Border Height="150" Margin="0,0,0,14" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0"
                    EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling" ItemsSource="{Binding ActivityRows}">
            <DataGrid.Columns>
              <DataGridTextColumn Width="105" Binding="{Binding Date}" Header="Fecha" />
              <DataGridTextColumn Width="180" Binding="{Binding Principal}" Header="Operación" />
              <DataGridTextColumn Width="2*" Binding="{Binding Detail}" Header="Descripción" />
              <DataGridTextColumn Width="180" Binding="{Binding Status}" Header="Actividad" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>

        <Border Margin="0,0,0,16" Padding="16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <StackPanel>
            <DockPanel Margin="0,0,0,12">
              <Button DockPanel.Dock="Right" Style="{StaticResource ActionButton}" Command="{Binding ClearFormCommand}" Content="Limpiar formulario" />
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,8,10,0" Style="{StaticResource FieldLabel}" Text="Acción" />
                <ComboBox Width="220" Style="{StaticResource FieldBox}" ItemsSource="{Binding ActionOptions}" SelectedItem="{Binding SelectedAction}" />
              </StackPanel>
            </DockPanel>
            <WrapPanel>
              <StackPanel Width="235" Margin="0,0,14,12">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" />
                <TextBox Style="{StaticResource FieldBox}" Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>
              <StackPanel Width="180" Margin="0,0,14,12">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Fecha" />
                <DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ActionDate}" />
              </StackPanel>
              <StackPanel Width="235" Margin="0,0,14,12"
                          Visibility="{Binding IsWorkerAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Silla disponible" />
                <ComboBox Style="{StaticResource FieldBox}" DisplayMemberPath="Display"
                          ItemsSource="{Binding AvailableChairOptions}" SelectedItem="{Binding SelectedAvailableChair}" />
              </StackPanel>
              <StackPanel Width="300" Margin="0,0,14,12">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" />
                <TextBox Style="{StaticResource FieldBox}" Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>
            </WrapPanel>
            <Button Width="170" HorizontalAlignment="Left" Style="{StaticResource ActionButton}"
                    Command="{Binding SaveActionCommand}" Content="Guardar" />
          </StackPanel>
        </Border>

        <TextBlock Margin="0,0,0,6" FontSize="18" FontWeight="SemiBold" Text="Trabajadores" />
        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Right" Padding="12,5" Command="{Binding OpenSelectedWorkerProfileCommand}"
                  Content="Abrir perfil seleccionado" />
          <TextBlock VerticalAlignment="Center" Foreground="#5B6575"
                     Text="Haz doble clic en un trabajador para abrir su perfil." />
        </DockPanel>
        <Border MinHeight="190" Margin="0,0,0,16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0"
                    EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling" ItemsSource="{Binding Workers}"
                    SelectedItem="{Binding SelectedWorkerRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MouseDoubleClick="OnWorkerDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Width="2*" Binding="{Binding Name}" Header="Nombre" />
              <DataGridTextColumn Width="120" Binding="{Binding EntryDate}" Header="Ingreso" />
              <DataGridTextColumn Width="150" Binding="{Binding Chair}" Header="Silla actual" />
              <DataGridTextColumn Width="130" Binding="{Binding Debt}" Header="Deuda" />
              <DataGridTextColumn Width="110" Binding="{Binding State}" Header="Estado" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>

        <TextBlock Margin="0,0,0,6" FontSize="18" FontWeight="SemiBold" Text="Sillas" />
        <Border MinHeight="190" Margin="0,0,0,12" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0"
                    EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling" ItemsSource="{Binding Chairs}"
                    SelectedItem="{Binding SelectedChairRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
            <DataGrid.Columns>
              <DataGridTextColumn Width="150" Binding="{Binding Name}" Header="Nombre" />
              <DataGridTextColumn Width="120" Binding="{Binding CreationDate}" Header="Creación" />
              <DataGridTextColumn Width="2*" Binding="{Binding Worker}" Header="Trabajador asignado" />
              <DataGridTextColumn Width="3*" Binding="{Binding Description}" Header="Descripción" />
              <DataGridTextColumn Width="110" Binding="{Binding State}" Header="Estado" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>
        <Border Padding="14" Background="#F8FAFC" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <StackPanel>
            <TextBlock Margin="0,0,0,10" FontWeight="SemiBold" Text="Editar silla seleccionada" />
            <WrapPanel>
              <StackPanel Width="210" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ChairEditName, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="170" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de creación" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ChairEditCreationDate}" /></StackPanel>
              <StackPanel Width="300" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ChairEditDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            </WrapPanel>
            <WrapPanel>
              <Button Style="{StaticResource ActionButton}" Command="{Binding SaveSelectedChairCommand}" Content="Guardar cambios" />
              <CheckBox Margin="8,8,12,0" IsChecked="{Binding ConfirmChairDelete}" Content="Confirmo eliminar" />
              <Button Style="{StaticResource ActionButton}" Command="{Binding DeleteSelectedChairCommand}" Content="Eliminar silla" />
            </WrapPanel>
          </StackPanel>
        </Border>
        <TextBlock Margin="0,12,0,0" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>

    <Grid Margin="26">
      <Grid.Style>
        <Style TargetType="Grid">
          <Setter Property="Visibility" Value="Collapsed" />
          <Style.Triggers><DataTrigger Binding="{Binding IsWorkerProfileOpen}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
        </Style>
      </Grid.Style>
      <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
      <ScrollViewer Grid.Row="0" MaxHeight="340" VerticalScrollBarVisibility="Auto">
        <StackPanel>
          <DockPanel Margin="0,0,0,12">
            <Button DockPanel.Dock="Right" Style="{StaticResource ActionButton}" Command="{Binding CloseWorkerProfileCommand}" Content="Cerrar perfil" />
            <StackPanel><TextBlock FontSize="26" FontWeight="SemiBold" Text="Perfil del trabajador" /><TextBlock Foreground="#5B6575" Text="Los cambios de datos válidos se guardan automáticamente." /></StackPanel>
          </DockPanel>
          <WrapPanel>
            <StackPanel Width="235" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Width="170" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de ingreso" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ProfileEntryDate}" /></StackPanel>
            <StackPanel Width="170" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de retiro" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ProfileExitDate}" /></StackPanel>
            <StackPanel Width="300" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ProfileDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
          </WrapPanel>
          <WrapPanel Margin="0,0,0,10">
            <TextBlock Margin="0,0,24,0" FontWeight="SemiBold" Text="{Binding ProfileChair, StringFormat=Silla actual: {0}}" />
            <TextBlock Margin="0,0,24,0" FontWeight="SemiBold" Text="{Binding ProfileDebt, StringFormat=Deuda actual: {0}}" />
            <TextBlock Text="{Binding ProfileWeeklyRates, StringFormat=Tarifas históricas: {0}}" TextWrapping="Wrap" />
          </WrapPanel>
          <WrapPanel>
            <StackPanel Width="150" Margin="0,0,10,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de pago" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding PaymentDate}" /></StackPanel>
            <StackPanel Width="150" Margin="0,0,10,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Valor pagado" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Width="240" Margin="0,0,10,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding PaymentDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <Button Margin="0,23,10,10" Style="{StaticResource ActionButton}" Command="{Binding RegisterWorkerPaymentCommand}" Content="Registrar pago" />
          </WrapPanel>
          <WrapPanel>
            <ComboBox Width="220" Margin="0,0,10,10" Style="{StaticResource FieldBox}" DisplayMemberPath="Display" ItemsSource="{Binding AvailableChairOptions}" SelectedItem="{Binding ProfileSelectedChair}" />
            <Button Style="{StaticResource ActionButton}" Command="{Binding AssignProfileChairCommand}" Content="Asignar o cambiar silla" />
            <Button Style="{StaticResource ActionButton}" Command="{Binding UnassignProfileChairCommand}" Content="Retirar silla" />
            <DatePicker Width="150" Margin="8,0,10,10" Style="{StaticResource FieldBox}" SelectedDate="{Binding RetirementDate}" />
            <Button Style="{StaticResource ActionButton}" Command="{Binding RetireWorkerCommand}" Content="Retirar trabajador del local" />
          </WrapPanel>
          <DockPanel Margin="0,4,0,8">
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
              <ComboBox Width="190" Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" />
              <DatePicker Width="135" Margin="8,0,0,0" SelectedDate="{Binding CustomPeriodFrom}" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}" />
              <DatePicker Width="135" Margin="8,0,0,0" SelectedDate="{Binding CustomPeriodThrough}" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}" />
            </StackPanel>
            <TextBlock FontSize="18" FontWeight="SemiBold" Text="Historial cronológico" />
          </DockPanel>
          <TextBlock Margin="0,0,0,8" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </StackPanel>
      </ScrollViewer>
      <DataGrid Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.VerticalScrollBarVisibility="Auto"
                ItemsSource="{Binding WorkerHistoryRows}">
        <DataGrid.Columns>
          <DataGridTextColumn Width="105" Binding="{Binding Date}" Header="Fecha" />
          <DataGridTextColumn Width="190" Binding="{Binding Principal}" Header="Operación" />
          <DataGridTextColumn Width="3*" Binding="{Binding Detail}" Header="Detalle" />
          <DataGridTextColumn Width="130" Binding="{Binding Amount}" Header="Valor" />
          <DataGridTextColumn Width="180" Binding="{Binding Status}" Header="Estado" />
        </DataGrid.Columns>
      </DataGrid>
    </Grid>
  </Grid>
</UserControl>
