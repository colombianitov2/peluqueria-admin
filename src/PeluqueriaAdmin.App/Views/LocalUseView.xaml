<UserControl x:Class="PeluqueriaAdmin.App.Views.LocalUseView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:LocalUseViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Margin" Value="0,0,0,5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#273449" />
    </Style>
    <Style x:Key="FieldBox" TargetType="Control">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="9,6" />
    </Style>
    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="#EEF2FF" />
      <Setter Property="BorderBrush" Value="#A5B4FC" />
    </Style>
  </UserControl.Resources>

  <Grid Background="#F5F7FA">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <ScrollViewer.Style>
        <Style TargetType="ScrollViewer">
          <Setter Property="Visibility" Value="Visible" />
          <Style.Triggers>
            <DataTrigger Binding="{Binding IsWorkerProfileOpen}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
            <DataTrigger Binding="{Binding IsChairProfileOpen}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger>
          </Style.Triggers>
        </Style>
      </ScrollViewer.Style>
      <StackPanel Margin="26">
        <DockPanel Margin="0,0,0,14" LastChildFill="True">
          <StackPanel DockPanel.Dock="Right" Margin="18,0,0,0" MinWidth="190">
            <TextBlock HorizontalAlignment="Right" Style="{StaticResource FieldLabel}" Text="Periodo a mostrar" />
            <ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" />
            <WrapPanel Margin="0,6,0,0" HorizontalAlignment="Right"
                       Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}">
              <DatePicker Width="138" Margin="0,0,6,0" SelectedDate="{Binding CustomPeriodFrom}" />
              <DatePicker Width="138" SelectedDate="{Binding CustomPeriodThrough}" />
            </WrapPanel>
          </StackPanel>
          <StackPanel>
            <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#172033" Text="Uso del local" />
            <TextBlock Margin="0,5,0,0" Foreground="#5B6575"
                       Text="Sillas y trabajadores, periodos completos de siete días, cuotas y pagos." TextWrapping="Wrap" />
          </StackPanel>
        </DockPanel>

        <WrapPanel Margin="0,0,0,14">
          <Border Width="190" Margin="0,0,12,0" Padding="16" Background="#EFF6FF" CornerRadius="7">
            <StackPanel><TextBlock Foreground="#475569" Text="Total de sillas" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding TotalChairs}" /></StackPanel>
          </Border>
          <Border Width="190" Margin="0,0,12,0" Padding="16" Background="#F0FDF4" CornerRadius="7">
            <StackPanel><TextBlock Foreground="#475569" Text="Trabajadores vigentes" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding CurrentWorkers}" /></StackPanel>
          </Border>
          <Border Width="190" Padding="16" Background="#FFF7ED" CornerRadius="7">
            <StackPanel><TextBlock Foreground="#475569" Text="Sillas disponibles" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding AvailableChairs}" /></StackPanel>
          </Border>
        </WrapPanel>

        <Border Margin="0,0,0,16" Padding="16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <StackPanel>
            <DockPanel Margin="0,0,0,12">
              <StackPanel Orientation="Horizontal">
                <TextBlock Margin="0,8,10,0" Style="{StaticResource FieldLabel}" Text="Acción" />
                <ComboBox Width="220" Style="{StaticResource FieldBox}" ItemsSource="{Binding ActionOptions}" SelectedItem="{Binding SelectedAction}" />
              </StackPanel>
            </DockPanel>
            <WrapPanel>
              <StackPanel Width="235" Margin="0,0,14,12">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" />
                <TextBox Style="{StaticResource FieldBox}" Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>
              <StackPanel Width="180" Margin="0,0,14,12">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Fecha" />
                <DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ActionDate, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>
              <StackPanel Width="235" Margin="0,0,14,12"
                          Visibility="{Binding IsWorkerAction, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Silla inicial (opcional)" />
                <ComboBox Style="{StaticResource FieldBox}" DisplayMemberPath="Display"
                          ItemsSource="{Binding NewWorkerChairOptions}" SelectedItem="{Binding SelectedNewWorkerChair}" />
              </StackPanel>
              <StackPanel Width="300" Margin="0,0,14,12">
                <TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" />
                <TextBox Style="{StaticResource FieldBox}" Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}" />
              </StackPanel>
            </WrapPanel>
            <TextBlock Margin="0,0,0,10" Foreground="#9A3412" FontWeight="SemiBold"
                       Text="Borrador recuperado: verifica la fecha visible antes de guardar."
                       Visibility="{Binding HasRecoveredActionDraft, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <Button Width="170" HorizontalAlignment="Left" Style="{StaticResource ActionButton}"
                    Command="{Binding SaveActionCommand}" Content="Guardar" />
          </StackPanel>
        </Border>

        <TextBlock Margin="0,0,0,6" FontSize="18" FontWeight="SemiBold" Text="Trabajadores" />
        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Right" Padding="12,5" Command="{Binding OpenSelectedWorkerProfileCommand}"
                  Content="Abrir perfil seleccionado" />
          <TextBlock VerticalAlignment="Center" Foreground="#5B6575"
                     Text="Haz doble clic en un trabajador para abrir su perfil." />
        </DockPanel>
        <Border MinHeight="190" Margin="0,0,0,16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0"
                    EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling" ItemsSource="{Binding Workers}"
                    SelectedItem="{Binding SelectedWorkerRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MouseDoubleClick="OnWorkerDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Width="220" Binding="{Binding Name}" Header="Nombre" />
              <DataGridTextColumn Width="120" Binding="{Binding EntryDate}" Header="Ingreso" />
              <DataGridTextColumn Width="150" Binding="{Binding Chair}" Header="Silla actual" />
              <DataGridTextColumn Width="130" Binding="{Binding Debt}" Header="Deuda" />
              <DataGridTextColumn Width="110" Binding="{Binding State}" Header="Estado" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>

        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Right" Padding="12,5" Command="{Binding OpenSelectedChairProfileCommand}" Content="Abrir perfil seleccionado" />
          <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Sillas" />
        </DockPanel>
        <Border MinHeight="190" Margin="0,0,0,12" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0"
                    EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                    VirtualizingPanel.VirtualizationMode="Recycling" ItemsSource="{Binding Chairs}"
                    SelectedItem="{Binding SelectedChairRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MouseDoubleClick="OnChairDoubleClick">
            <DataGrid.Columns>
              <DataGridTextColumn Width="150" Binding="{Binding Name}" Header="Nombre" />
              <DataGridTextColumn Width="120" Binding="{Binding CreationDate}" Header="Creación" />
              <DataGridTextColumn Width="230" Binding="{Binding Worker}" Header="Trabajador asignado" />
              <DataGridTextColumn Width="340" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Description}" Header="Descripción" />
              <DataGridTextColumn Width="110" Binding="{Binding State}" Header="Estado" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>
        <TextBlock Margin="0,12,0,0" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>

    <Grid Margin="18,8">
      <Grid.Style>
        <Style TargetType="Grid">
          <Setter Property="Visibility" Value="Collapsed" />
          <Style.Triggers><DataTrigger Binding="{Binding IsWorkerProfileOpen}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
        </Style>
      </Grid.Style>
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <StackPanel x:Name="WorkerProfileHeader" Grid.Row="0">
          <DockPanel Margin="0,0,0,6">
            <Button DockPanel.Dock="Right" Style="{StaticResource ActionButton}" Command="{Binding CloseWorkerProfileCommand}" Content="Cerrar perfil" />
            <StackPanel><TextBlock FontSize="22" FontWeight="SemiBold" Text="Perfil del trabajador" /><TextBlock FontSize="11" Foreground="#5B6575" Text="Los cambios de datos válidos se guardan automáticamente." /></StackPanel>
          </DockPanel>
          <UniformGrid Margin="0,0,0,5" Columns="4">
            <Border Margin="0,0,5,4" Padding="4" Background="#F8FAFC" CornerRadius="4"><StackPanel><TextBlock FontSize="10" Foreground="#64748B" Text="Silla actual" /><TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding ProfileChair}" TextWrapping="Wrap" /></StackPanel></Border>
            <Border Margin="0,0,5,4" Padding="4" Background="#FFF7ED" CornerRadius="4"><StackPanel><TextBlock FontSize="10" Foreground="#64748B" Text="Deuda acumulada" /><TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding ProfileDebt}" /></StackPanel></Border>
            <Border Margin="0,0,5,4" Padding="4" Background="#F0FDF4" CornerRadius="4"><StackPanel><TextBlock FontSize="10" Foreground="#64748B" Text="Saldo a favor" /><TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding ProfileCredit}" /></StackPanel></Border>
            <Border Margin="0,0,0,4" Padding="4" Background="#F8FAFC" CornerRadius="4"><StackPanel><TextBlock FontSize="10" Foreground="#64748B" Text="Próxima cuota" /><TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding ProfileNextCharge}" TextWrapping="Wrap" /></StackPanel></Border>
            <Border Margin="0,0,5,0" Padding="4" Background="#F8FAFC" CornerRadius="4"><StackPanel><TextBlock FontSize="10" Foreground="#64748B" Text="Valor de la cuota" /><TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding ProfileNextChargeAmount}" /></StackPanel></Border>
            <Border Margin="0,0,5,0" Padding="4" Background="#EEF2FF" CornerRadius="4"><StackPanel><TextBlock FontSize="10" Foreground="#64748B" Text="Próximo pago requerido" /><TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding ProfileNextRequiredPayment}" TextWrapping="Wrap" /></StackPanel></Border>
            <Border Padding="4" Background="#F0FDFA" CornerRadius="4"><StackPanel><TextBlock FontSize="10" Foreground="#64748B" Text="Cobertura estimada hasta" /><TextBlock FontSize="11" FontWeight="SemiBold" Text="{Binding ProfileCoveredThrough}" TextWrapping="Wrap" /></StackPanel></Border>
          </UniformGrid>
          <TabControl Margin="0,-2,0,6" SelectedIndex="{Binding ProfileTabIndex}">
            <TabItem Header="Datos del trabajador">
              <Grid Margin="8,7">
                <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,6"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,6"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ProfileDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de ingreso" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ProfileEntryDate}" /></StackPanel>
                <TextBlock Grid.Row="2" Grid.ColumnSpan="2" Margin="0,4,0,0" FontSize="10" Foreground="#475569"
                           Text="{Binding ProfileWeeklyRates, StringFormat=Tarifas históricas: {0}}" TextWrapping="Wrap" />
              </Grid>
            </TabItem>
            <TabItem Header="Registrar pago">
              <StackPanel Margin="8,7">
                <WrapPanel>
                  <StackPanel Width="125" Margin="0,0,8,4"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de pago" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding PaymentDate}" /></StackPanel>
                  <StackPanel Width="125" Margin="0,0,8,4"><TextBlock Style="{StaticResource FieldLabel}" Text="Valor pagado" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                  <StackPanel Width="180" Margin="0,0,8,4"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding PaymentDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
                  <Button Margin="0,23,0,4" Style="{StaticResource ActionButton}" Command="{Binding RegisterWorkerPaymentCommand}" Content="Registrar pago" />
                </WrapPanel>
                <TextBlock Foreground="#475569" Text="Puedes registrar pagos anticipados. El excedente quedará como saldo a favor y se aplicará a las próximas cuotas." TextWrapping="Wrap" />
              </StackPanel>
            </TabItem>
            <TabItem Header="Silla">
              <StackPanel Margin="8,7">
                <WrapPanel>
                  <ComboBox Width="205" Margin="0,0,8,4" Style="{StaticResource FieldBox}" DisplayMemberPath="Display" ItemsSource="{Binding WorkerProfileChairOptions}" SelectedItem="{Binding WorkerProfileSelectedChair}" />
                  <Button Style="{StaticResource ActionButton}" Command="{Binding AssignProfileChairCommand}" Content="Asignar o cambiar silla" />
                  <Button Style="{StaticResource ActionButton}" Command="{Binding UnassignProfileChairCommand}" Content="Retirar silla" />
                </WrapPanel>
                <WrapPanel>
                  <CheckBox Margin="8,8,8,0" IsChecked="{Binding ConfirmWorkerDelete}" Content="Confirmo eliminar" />
                  <Button Style="{StaticResource ActionButton}" Command="{Binding DeleteWorkerCommand}" Content="Eliminar trabajador" />
                </WrapPanel>
                <TextBlock FontSize="11" Foreground="#9A3412" Text="Al eliminar se conserva el historial y se libera la silla." />
              </StackPanel>
            </TabItem>
          </TabControl>
          <TextBlock Margin="0,0,0,8" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </StackPanel>
      <Border x:Name="WorkerHistoryBand" Grid.Row="1" Margin="0,4,0,8" Padding="10,8" Background="#EAF0F7" CornerRadius="6">
        <DockPanel>
          <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
            <TextBlock Margin="0,8,8,0" Foreground="#475569" Text="Periodo a mostrar" />
            <ComboBox Width="190" Style="{StaticResource FieldBox}" ItemsSource="{Binding WorkerHistoryPeriodOptions}" SelectedItem="{Binding SelectedWorkerHistoryPeriod}" />
            <DatePicker Width="135" Margin="8,0,0,0" SelectedDate="{Binding CustomPeriodFrom}" Visibility="{Binding ShowCustomWorkerHistoryPeriod, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <DatePicker Width="135" Margin="8,0,0,0" SelectedDate="{Binding CustomPeriodThrough}" Visibility="{Binding ShowCustomWorkerHistoryPeriod, Converter={StaticResource BooleanToVisibilityConverter}}" />
          </StackPanel>
          <TextBlock VerticalAlignment="Center" FontSize="18" FontWeight="SemiBold" Text="Historial cronológico" />
        </DockPanel>
      </Border>
      <DataGrid x:Name="WorkerHistoryGrid" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True"
                VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.VerticalScrollBarVisibility="Auto"
                ItemsSource="{Binding WorkerHistoryRows}">
        <DataGrid.Columns>
          <DataGridTextColumn Width="105" Binding="{Binding Date}" Header="Fecha" />
          <DataGridTextColumn Width="190" Binding="{Binding Principal}" Header="Operación" />
          <DataGridTextColumn Width="340" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Detail}" Header="Detalle" />
          <DataGridTextColumn Width="130" Binding="{Binding Amount}" Header="Valor" />
          <DataGridTextColumn Width="180" Binding="{Binding Status}" Header="Estado" />
        </DataGrid.Columns>
      </DataGrid>
    </Grid>

    <Grid Margin="26">
      <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsChairProfileOpen}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
      <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
      <StackPanel Grid.Row="0">
        <DockPanel Margin="0,0,0,12">
          <Button DockPanel.Dock="Right" Style="{StaticResource ActionButton}" Command="{Binding CloseChairProfileCommand}" Content="Cerrar perfil" />
          <StackPanel><TextBlock FontSize="26" FontWeight="SemiBold" Text="Perfil de la silla" /><TextBlock Foreground="#5B6575" Text="Los cambios válidos se guardan automáticamente." /></StackPanel>
        </DockPanel>
        <WrapPanel>
          <StackPanel Width="220" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ChairEditName, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
          <StackPanel Width="175" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de creación" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ChairEditCreationDate}" /></StackPanel>
          <StackPanel Width="340" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ChairEditDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
        </WrapPanel>
        <WrapPanel>
          <TextBlock Margin="0,7,18,0" FontWeight="SemiBold" Text="{Binding ChairAssignedWorkerSummary}" />
          <TextBlock Margin="0,7,18,0" FontWeight="SemiBold" Text="{Binding SelectedChairRow.State, StringFormat=Estado: {0}}" />
          <CheckBox Margin="0,8,12,0" IsChecked="{Binding ConfirmChairDelete}" Content="Confirmo eliminar la silla" />
          <Button Style="{StaticResource ActionButton}" Command="{Binding DeleteSelectedChairCommand}" Content="Eliminar silla" />
        </WrapPanel>
        <TextBlock Margin="0,0,0,8" Foreground="#9A3412" Text="Si está ocupada, el trabajador permanecerá registrado y quedará Sin silla." TextWrapping="Wrap" />
        <DockPanel Margin="0,4,0,8"><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><TextBlock Margin="0,8,8,0" Text="Periodo a mostrar" /><ComboBox Width="190" Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" /></StackPanel><TextBlock FontSize="18" FontWeight="SemiBold" Text="Historial de la silla" /></DockPanel>
        <TextBlock Margin="0,0,0,8" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </StackPanel>
      <DataGrid Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding ChairHistoryRows}" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
        <DataGrid.Columns><DataGridTextColumn Width="110" Binding="{Binding Date}" Header="Fecha" /><DataGridTextColumn Width="210" Binding="{Binding Principal}" Header="Evento" /><DataGridTextColumn Width="340" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Detail}" Header="Detalle" /><DataGridTextColumn Width="250" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Status}" Header="Información" /></DataGrid.Columns>
      </DataGrid>
    </Grid>
  </Grid>
</UserControl>
