<UserControl x:Class="PeluqueriaAdmin.App.Views.AdministrationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:oxy="http://oxyplot.org/wpf"
             xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:AdministrationViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Margin" Value="0,0,0,5" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="#273449" />
    </Style>
    <Style x:Key="FieldBox" TargetType="Control">
      <Setter Property="MinHeight" Value="36" />
      <Setter Property="Padding" Value="9,6" />
    </Style>
    <Style x:Key="ActionButton" TargetType="Button">
      <Setter Property="Margin" Value="0,0,8,8" />
      <Setter Property="Padding" Value="12,7" />
      <Setter Property="Background" Value="#EEF2FF" />
      <Setter Property="BorderBrush" Value="#A5B4FC" />
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
    <Grid Margin="26">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" />
      </Grid.RowDefinitions>
      <DockPanel Grid.Row="0" Margin="0,0,0,14" LastChildFill="True">
        <StackPanel DockPanel.Dock="Right" Margin="18,0,0,0" MinWidth="190"
                    Visibility="{Binding ShowPeriodSelector, Converter={StaticResource BooleanToVisibilityConverter}}">
          <TextBlock HorizontalAlignment="Right" Style="{StaticResource FieldLabel}" Text="Periodo a mostrar" />
          <ComboBox Style="{StaticResource FieldBox}"
                    ItemsSource="{Binding PeriodOptions}"
                    SelectedItem="{Binding SelectedPeriod}" />
          <WrapPanel Margin="0,6,0,0"
                     HorizontalAlignment="Right"
                     Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}">
            <DatePicker Width="138" Margin="0,0,6,0" SelectedDate="{Binding CustomPeriodFrom}" />
            <DatePicker Width="138" SelectedDate="{Binding CustomPeriodThrough}" />
          </WrapPanel>
        </StackPanel>
        <StackPanel>
          <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#172033" Text="{Binding Title}" />
          <TextBlock Margin="0,5,0,0" Foreground="#5B6575" Text="{Binding Description}" TextWrapping="Wrap" />
        </StackPanel>
      </DockPanel>

      <WrapPanel Grid.Row="1" Margin="0,0,0,12" HorizontalAlignment="Right">
        <WrapPanel Visibility="{Binding ShowSpecificDateQuery, Converter={StaticResource BooleanToVisibilityConverter}}">
          <DatePicker Width="155" Margin="0,0,8,0" SelectedDate="{Binding SpecificDate}" />
          <Button Style="{StaticResource ActionButton}" Command="{Binding ConsultPeriodCommand}" Content="Consultar" />
        </WrapPanel>
        <WrapPanel Visibility="{Binding ShowSpecificYearQuery, Converter={StaticResource BooleanToVisibilityConverter}}">
          <TextBlock Margin="0,8,8,0" Style="{StaticResource FieldLabel}" Text="Año a consultar" />
          <TextBox Width="110" Margin="0,0,8,8" Style="{StaticResource FieldBox}" Text="{Binding SpecificYearText, UpdateSourceTrigger=PropertyChanged}" />
          <Button Style="{StaticResource ActionButton}" Command="{Binding ConsultPeriodCommand}" Content="Consultar" />
        </WrapPanel>
      </WrapPanel>
      <TextBlock Grid.Row="2" Margin="0,0,0,8" Foreground="#64748B" Text="{Binding HistoricalRecordsWithoutTime}" TextWrapping="Wrap" />

      <Border Grid.Row="3" Margin="0,0,0,14" Padding="16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7" Visibility="{Binding ShowFinancialClose, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
          <DockPanel Margin="0,0,0,10">
            <WrapPanel DockPanel.Dock="Right"><DatePicker Width="155" Margin="0,0,8,0" SelectedDate="{Binding SpecificDate}" /><Button Style="{StaticResource ActionButton}" Command="{Binding ConsultFinancialMonthCommand}" Content="Consultar mes" /></WrapPanel>
            <StackPanel><TextBlock FontSize="20" FontWeight="SemiBold" Text="Cierre mensual" /><TextBlock Foreground="#475569" Text="{Binding FinancialCloseState}" TextWrapping="Wrap" /></StackPanel>
          </DockPanel>
          <ItemsControl ItemsSource="{Binding FinancialMonthRows}">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate><DataTemplate><Border Margin="3" Padding="8" Background="#F8FAFC" CornerRadius="4"><StackPanel><TextBlock FontSize="11" Foreground="#64748B" Text="{Binding Concept}" TextWrapping="Wrap" /><TextBlock FontWeight="SemiBold" Text="{Binding Amount}" /></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Margin="0,12,0,6" FontSize="16" FontWeight="SemiBold" Text="Compromisos considerados para el cierre" />
          <DataGrid MaxHeight="230" AutoGenerateColumns="False" CanUserAddRows="False" ItemsSource="{Binding FinancialCommitmentRows}">
            <DataGrid.Columns>
              <DataGridTextColumn Width="130" IsReadOnly="True" Header="Origen" Binding="{Binding Origin}" /><DataGridTextColumn Width="210" IsReadOnly="True" Header="Nombre" Binding="{Binding Name}" /><DataGridTextColumn Width="105" IsReadOnly="True" Header="Fecha" Binding="{Binding DueDate}" /><DataGridTextColumn Width="120" IsReadOnly="True" Header="Esperado" Binding="{Binding Expected}" /><DataGridTextColumn Width="120" IsReadOnly="True" Header="Real" Binding="{Binding Actual}" /><DataGridTextColumn Width="100" IsReadOnly="True" Header="Estado" Binding="{Binding State}" /><DataGridCheckBoxColumn Width="75" Header="Ignorar" Binding="{Binding IsIgnored}" /><DataGridTextColumn Width="250" Header="Motivo obligatorio" Binding="{Binding ExclusionReason, UpdateSourceTrigger=PropertyChanged}" />
            </DataGrid.Columns>
          </DataGrid>
          <WrapPanel Margin="0,10,0,0"><Button Style="{StaticResource ActionButton}" Command="{Binding SaveFinancialExclusionsCommand}" Content="Guardar exclusiones" /><Button Style="{StaticResource ActionButton}" Command="{Binding CloseFinancialMonthCommand}" Content="Cerrar mes" /><CheckBox Margin="8,8,8,0" IsChecked="{Binding ConfirmReopenMonth}" Content="Confirmo reabrir" /><Button Style="{StaticResource ActionButton}" Command="{Binding ReopenFinancialMonthCommand}" Content="Reabrir mes" /></WrapPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="3" Margin="0,0,0,14" Padding="16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7" Visibility="{Binding ShowAnnualClose, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
          <DockPanel>
            <WrapPanel DockPanel.Dock="Right"><CheckBox Margin="0,8,8,0" IsChecked="{Binding ConfirmCloseYear}" Content="Confirmo cerrar año" /><Button Style="{StaticResource ActionButton}" Command="{Binding CloseYearCommand}" Content="Cerrar año" /></WrapPanel>
            <StackPanel><TextBlock FontSize="20" FontWeight="SemiBold" Text="Balance y cierre anual" /><TextBlock Foreground="#475569" Text="{Binding FinancialCloseState}" TextWrapping="Wrap" /></StackPanel>
          </DockPanel>
          <ItemsControl Margin="0,10,0,0" ItemsSource="{Binding AnnualSummaryRows}">
            <ItemsControl.ItemsPanel><ItemsPanelTemplate><UniformGrid Columns="3" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate><DataTemplate><Border Margin="3" Padding="8" Background="#F8FAFC" CornerRadius="4"><StackPanel><TextBlock FontSize="11" Foreground="#64748B" Text="{Binding Concept}" TextWrapping="Wrap" /><TextBlock FontWeight="SemiBold" Text="{Binding Amount}" /></StackPanel></Border></DataTemplate></ItemsControl.ItemTemplate>
          </ItemsControl>
          <TextBlock Margin="0,12,0,6" FontSize="16" FontWeight="SemiBold" Text="Compromisos pendientes conocidos del año" />
          <DataGrid MaxHeight="230" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding AnnualCommitmentRows}">
            <DataGrid.Columns>
              <DataGridTextColumn Width="105" Header="Fecha" Binding="{Binding DueDate}" />
              <DataGridTextColumn Width="200" Header="Nombre" Binding="{Binding Name}" />
              <DataGridTextColumn Width="150" Header="Tipo" Binding="{Binding Type}" />
              <DataGridTextColumn Width="125" Header="Valor" Binding="{Binding Amount}" />
              <DataGridTextColumn Width="280" ElementStyle="{StaticResource WrappingCellText}" Header="Descripción" Binding="{Binding Description}" />
              <DataGridTextColumn Width="100" Header="Estado" Binding="{Binding Status}" />
            </DataGrid.Columns>
          </DataGrid>
          <TextBlock Margin="0,12,0,6" FontSize="16" FontWeight="SemiBold" Text="Ingresos y egresos por mes" />
          <oxy:PlotView Height="300" Model="{Binding AnnualIncomeChart}" />
        </StackPanel>
      </Border>

      <WrapPanel Grid.Row="3" Margin="0,0,0,14"
                 Visibility="{Binding ShowLocalUseSummary, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border Width="190" Margin="0,0,12,0" Padding="16" Background="#EFF6FF" CornerRadius="7">
          <StackPanel><TextBlock Foreground="#475569" Text="Total de sillas" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding TotalChairs}" /></StackPanel>
        </Border>
        <Border Width="190" Margin="0,0,12,0" Padding="16" Background="#F0FDF4" CornerRadius="7">
          <StackPanel><TextBlock Foreground="#475569" Text="Trabajadores vigentes" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding CurrentHairdressers}" /></StackPanel>
        </Border>
        <Border Width="190" Padding="16" Background="#FFF7ED" CornerRadius="7">
          <StackPanel><TextBlock Foreground="#475569" Text="Sillas disponibles" /><TextBlock FontSize="26" FontWeight="SemiBold" Text="{Binding AvailableChairs}" /></StackPanel>
        </Border>
      </WrapPanel>

      <Separator Grid.Row="4" Margin="0,0,0,12"
                 Visibility="{Binding ShowLocalUseSummary, Converter={StaticResource BooleanToVisibilityConverter}}" />

      <StackPanel Grid.Row="5" Margin="0,0,0,16"
                  Visibility="{Binding ShowCharts, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Margin="0,0,0,8" FontSize="16" FontWeight="SemiBold" Text="Gráficos del periodo seleccionado" />
        <UniformGrid Columns="2" Rows="2">
          <GroupBox Margin="0,0,8,8" Header="Ingresos y egresos del periodo">
            <oxy:PlotView Height="260" Model="{Binding IncomeGoalChart}" />
          </GroupBox>
          <GroupBox Margin="8,0,0,8" Header="Composición de gastos por categoría">
            <Grid Height="300">
              <Grid.RowDefinitions><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
              <oxy:PlotView Model="{Binding ExpenseCompositionChart}" />
              <TextBlock HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#64748B" FontWeight="SemiBold" Text="Sin datos" Visibility="{Binding ShowExpenseCompositionNoData, Converter={StaticResource BooleanToVisibilityConverter}}" />
              <ScrollViewer Grid.Row="1" MaxHeight="105" HorizontalAlignment="Right" VerticalScrollBarVisibility="Auto">
                <ItemsControl ItemsSource="{Binding ExpenseLegendRows}">
                  <ItemsControl.ItemTemplate><DataTemplate><StackPanel Margin="4,2" Orientation="Horizontal"><Border Width="12" Height="12" Margin="0,2,7,0" Background="{Binding Color}" /><TextBlock MaxWidth="240" Text="{Binding Category}" TextWrapping="Wrap" /><TextBlock Margin="8,0,0,0" FontWeight="SemiBold" Text="{Binding Amount}" /><TextBlock Margin="6,0,0,0" Foreground="#64748B" Text="{Binding Percentage}" /></StackPanel></DataTemplate></ItemsControl.ItemTemplate>
                </ItemsControl>
              </ScrollViewer>
            </Grid>
          </GroupBox>
          <GroupBox Grid.ColumnSpan="2" Margin="0,8,0,0" Header="Evolución del resultado del periodo">
            <oxy:PlotView Height="280" Model="{Binding ResultEvolutionChart}" />
          </GroupBox>
        </UniformGrid>
      </StackPanel>

      <TextBlock Grid.Row="7" Margin="0,0,0,6" FontSize="16" FontWeight="SemiBold" Text="Registros" Visibility="{Binding ShowGeneralRecordsTable, Converter={StaticResource BooleanToVisibilityConverter}}" />
      <Border Grid.Row="8" Height="300" Margin="0,0,0,14" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7" Visibility="{Binding ShowGeneralRecordsTable, Converter={StaticResource BooleanToVisibilityConverter}}">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column" IsReadOnly="True" BorderThickness="0"
                  ItemsSource="{Binding Rows}" SelectedItem="{Binding SelectedRow}">
          <DataGrid.RowStyle>
            <Style TargetType="DataGridRow">
              <Setter Property="Tag" Value="{Binding DataContext, RelativeSource={RelativeSource AncestorType=DataGrid}}" />
              <Setter Property="ContextMenu">
                <Setter.Value>
                  <ContextMenu>
                    <MenuItem Header="Editar"
                              Visibility="{Binding PlacementTarget.DataContext.CanEdit, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Command="{Binding PlacementTarget.Tag.PrepareEditCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <Separator />
                    <MenuItem Header="Registrar compra"
                              Visibility="{Binding PlacementTarget.DataContext.IsInventoryProduct, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Command="{Binding PlacementTarget.Tag.PrepareInventoryPurchaseCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <MenuItem Header="Registrar pago"
                              Visibility="{Binding PlacementTarget.DataContext.IsObligation, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Command="{Binding PlacementTarget.Tag.PrepareObligationPaymentCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                    <MenuItem Header="Registrar realización"
                              Visibility="{Binding PlacementTarget.DataContext.IsPendingMaintenance, RelativeSource={RelativeSource AncestorType=ContextMenu}, Converter={StaticResource BooleanToVisibilityConverter}}"
                              Command="{Binding PlacementTarget.Tag.PrepareMaintenanceCompletionCommand, RelativeSource={RelativeSource AncestorType=ContextMenu}}"
                              CommandParameter="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource AncestorType=ContextMenu}}" />
                  </ContextMenu>
                </Setter.Value>
              </Setter>
            </Style>
          </DataGrid.RowStyle>
          <DataGrid.Columns>
            <DataGridTextColumn Width="105" Binding="{Binding Date}" Header="Fecha" />
            <DataGridTextColumn Width="220" Binding="{Binding Principal}" Header="Nombre" />
            <DataGridTextColumn Width="340" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Detail}" Header="Detalle o descripción" />
            <DataGridTextColumn Width="100" Binding="{Binding Quantity}" Header="Cantidad" />
            <DataGridTextColumn Width="135" Binding="{Binding Amount}" Header="Valor" />
            <DataGridTextColumn Width="165" Binding="{Binding Status}" Header="Estado" />
          </DataGrid.Columns>
        </DataGrid>
      </Border>

      <TextBlock Grid.Row="9" Margin="0,0,0,6" FontSize="16" FontWeight="SemiBold" Text="Registros del periodo" Visibility="{Binding ShowSimpleFinancialTable, Converter={StaticResource BooleanToVisibilityConverter}}" />
      <Border Grid.Row="10" Height="300" Margin="0,0,0,14" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7" Visibility="{Binding ShowSimpleFinancialTable, Converter={StaticResource BooleanToVisibilityConverter}}">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0" ItemsSource="{Binding SimpleFinancialRows}" SelectedItem="{Binding SelectedSimpleFinancialRow}">
          <DataGrid.Columns><DataGridTextColumn Width="105" Binding="{Binding Date}" Header="Fecha" /><DataGridTextColumn Width="220" Binding="{Binding Concept}" Header="Nombre" /><DataGridTextColumn Width="140" Binding="{Binding Amount}" Header="Valor" /><DataGridTextColumn Width="360" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
        </DataGrid>
      </Border>

      <StackPanel Grid.Row="11" Margin="0,0,0,14"
                  Visibility="{Binding ShowCollaboratorHistory, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Margin="0,0,0,6" FontSize="16" FontWeight="SemiBold" Text="Historial financiero del colaborador seleccionado" />
        <Border Height="170" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True"
                    ItemsSource="{Binding CollaboratorHistoryRows}">
            <DataGrid.Columns>
              <DataGridTextColumn Width="105" Header="Fecha" Binding="{Binding Date}" />
              <DataGridTextColumn Width="140" Header="Mes u operación" Binding="{Binding Principal}" />
              <DataGridTextColumn Width="300" ElementStyle="{StaticResource WrappingCellText}" Header="Porcentaje o descripción" Binding="{Binding Detail}" />
              <DataGridTextColumn Width="135" Header="Participación/pago" Binding="{Binding Amount}" />
              <DataGridTextColumn Width="220" Header="Pagado y pendiente" Binding="{Binding Status}" />
            </DataGrid.Columns>
          </DataGrid>
        </Border>
      </StackPanel>

      <Border Grid.Row="6" Margin="0,0,0,14" Padding="18" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7"
              Visibility="{Binding IsFormVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <StackPanel>
          <DockPanel Margin="0,0,0,12">
            <ItemsControl ItemsSource="{Binding ActionOptions}">
              <ItemsControl.ItemsPanel><ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button Style="{StaticResource ActionButton}"
                          Command="{Binding DataContext.SelectActionCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                          CommandParameter="{Binding}"
                          Content="{Binding}" />
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </DockPanel>

          <WrapPanel>
            <StackPanel Width="235" Margin="0,0,14,12" Visibility="{Binding ShowPrimary, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding PrimaryLabel}" />
              <TextBox Text="{Binding PrimaryText, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Style>
                  <Style TargetType="TextBox" BasedOn="{StaticResource FieldBox}">
                    <Style.Triggers><DataTrigger Binding="{Binding UsePrimarySelector}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
                  </Style>
                </TextBox.Style>
              </TextBox>
              <ComboBox IsEditable="True" IsTextSearchEnabled="True"
                        DisplayMemberPath="Display" ItemsSource="{Binding EntityOptions}" SelectedItem="{Binding SelectedEntityOption}">
                <ComboBox.Style>
                  <Style TargetType="ComboBox" BasedOn="{StaticResource FieldBox}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers><DataTrigger Binding="{Binding UsePrimarySelector}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                  </Style>
                </ComboBox.Style>
              </ComboBox>
              <TextBlock Margin="0,5,0,0" Foreground="#475569" Text="{Binding SelectedProductAvailability}" TextWrapping="Wrap" />
            </StackPanel>
            <StackPanel Width="220" Margin="0,0,14,12" Visibility="{Binding ShowSecondary, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding SecondaryLabel}" />
              <ComboBox IsEditable="True" ItemsSource="{Binding SecondaryOptions}"
                        Text="{Binding SecondaryText, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.Style>
                  <Style TargetType="ComboBox" BasedOn="{StaticResource FieldBox}">
                    <Style.Triggers><DataTrigger Binding="{Binding UseSecondarySelector}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers>
                  </Style>
                </ComboBox.Style>
              </ComboBox>
              <ComboBox IsEditable="True" IsTextSearchEnabled="True"
                        DisplayMemberPath="Display" ItemsSource="{Binding SecondaryEntityOptions}" SelectedItem="{Binding SelectedSecondaryEntityOption}">
                <ComboBox.Style>
                  <Style TargetType="ComboBox" BasedOn="{StaticResource FieldBox}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers><DataTrigger Binding="{Binding UseSecondarySelector}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers>
                  </Style>
                </ComboBox.Style>
              </ComboBox>
            </StackPanel>
            <StackPanel Width="190" Margin="0,0,14,12" Visibility="{Binding ShowExtra, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding ExtraLabel}" />
              <ComboBox Style="{StaticResource FieldBox}" IsEditable="True" ItemsSource="{Binding ExtraOptions}" Text="{Binding ExtraText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Width="175" Margin="0,0,14,12" Visibility="{Binding ShowDate, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding DateLabel}" />
              <DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding FormDate, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Width="190" Margin="0,0,14,12" Visibility="{Binding ShowEndDate, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding EndDateLabel}" />
              <DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding FormEndDate, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Width="175" Margin="0,0,14,12" Visibility="{Binding ShowAmount, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding AmountLabel}" />
              <TextBox Style="{StaticResource FieldBox}" IsReadOnly="{Binding IsAmountReadOnly}" Text="{Binding AmountText, UpdateSourceTrigger=PropertyChanged}" />
              <TextBlock Margin="0,5,0,0" Foreground="#475569" Text="{Binding CalculatedTotalText}" />
            </StackPanel>
            <StackPanel Width="210" Margin="0,0,14,12" Visibility="{Binding ShowSecondaryAmount, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding SecondaryAmountLabel}" />
              <TextBox Style="{StaticResource FieldBox}" Text="{Binding SecondaryAmountText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Width="170" Margin="0,0,14,12" Visibility="{Binding ShowQuantity, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{Binding QuantityLabel}" />
              <TextBox Style="{StaticResource FieldBox}" Text="{Binding QuantityText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Width="360" Margin="0,0,14,12" Visibility="{Binding ShowOptionalDescription, Converter={StaticResource BooleanToVisibilityConverter}}">
              <TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" />
              <TextBox MinHeight="58" Padding="9,6" AcceptsReturn="True" TextWrapping="Wrap"
                       Text="{Binding OptionalDescriptionText, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
          </WrapPanel>

          <WrapPanel Margin="0,2,0,0">
            <Button Margin="0,0,9,8" Padding="15,8" Background="#2E5BFF" Foreground="White"
                    Command="{Binding SaveCommand}" Content="{Binding SelectedAction}"
                    Visibility="{Binding ShowCommitAction, Converter={StaticResource BooleanToVisibilityConverter}}" />
            <WrapPanel Visibility="{Binding ShowRecordActions, Converter={StaticResource BooleanToVisibilityConverter}}">
              <Button Margin="0,0,9,8" Padding="13,8" Command="{Binding LoadSelectedCommand}" Content="Editar selección" />
              <CheckBox Margin="10,0,8,8" VerticalAlignment="Center" IsChecked="{Binding ConfirmDelete}" Content="Confirmo eliminar" />
              <Button Margin="0,0,0,8" Padding="13,8" Command="{Binding DeleteCommand}" Content="Eliminar selección" />
            </WrapPanel>
          </WrapPanel>

          <TextBlock Margin="0,8,0,0" Text="{Binding StatusMessage}" TextWrapping="Wrap">
            <TextBlock.Style>
              <Style TargetType="TextBlock">
                <Setter Property="Foreground" Value="#166534" />
                <Style.Triggers><DataTrigger Binding="{Binding IsError}" Value="True"><Setter Property="Foreground" Value="#B91C1C" /></DataTrigger></Style.Triggers>
              </Style>
            </TextBlock.Style>
          </TextBlock>
        </StackPanel>
      </Border>
    </Grid>
  </ScrollViewer>
</UserControl>
