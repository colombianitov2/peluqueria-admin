<UserControl x:Class="PeluqueriaAdmin.App.Views.ObligationsView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels" d:DataContext="{d:DesignInstance Type=viewModels:ObligationsViewModel, IsDesignTimeCreatable=False}"
 d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Margin" Value="0,0,0,5" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#273449" /></Style>
    <Style x:Key="FieldBox" TargetType="Control"><Setter Property="MinHeight" Value="36" /><Setter Property="Padding" Value="9,6" /></Style>
    <Style x:Key="ActionButton" TargetType="Button"><Setter Property="Margin" Value="0,0,8,8" /><Setter Property="Padding" Value="12,7" /><Setter Property="Background" Value="#EEF2FF" /><Setter Property="BorderBrush" Value="#A5B4FC" /></Style>
  </UserControl.Resources>
  <Grid Margin="26" Background="#F5F7FA">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,12"><TextBlock FontSize="28" FontWeight="SemiBold" Text="Obligaciones" /><TextBlock Margin="0,5,0,0" Foreground="#5B6575" Text="Catálogo permanente y pagos reales vinculados a cada vencimiento." /></StackPanel>
    <StackPanel Grid.Row="1">
      <WrapPanel Margin="0,0,0,8"><Button Style="{StaticResource ActionButton}" Command="{Binding ShowAddModeCommand}" Content="Agregar obligación" /><Button Style="{StaticResource ActionButton}" Command="{Binding ShowPaymentModeCommand}" Content="Registrar pago" /></WrapPanel>
      <Border Padding="14" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
        <Grid>
          <WrapPanel Visibility="{Binding IsAddMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Width="210" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre de la obligación" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Width="155" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Tipo" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding SelectedType}" /></StackPanel>
            <StackPanel Width="155" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Recurrencia" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding RecurrenceOptions}" SelectedItem="{Binding SelectedRecurrence}" /></StackPanel>
            <StackPanel Width="165" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Vencimiento inicial" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding InitialDueDate}" /></StackPanel>
            <StackPanel Width="160" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Valor esperado fijo" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ExpectedAmountText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Width="300" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ObligationDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding AddObligationCommand}" Content="Agregar obligación" />
            <Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding EditSelectedObligationCommand}" Content="Editar obligación seleccionada" />
            <Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding SaveObligationEditCommand}" Content="Guardar edición" />
            <CheckBox Margin="8,31,8,0" IsChecked="{Binding ConfirmDelete}" Content="Confirmo eliminar" />
            <Button Margin="0,23,0,8" Style="{StaticResource ActionButton}" Command="{Binding DeleteSelectedObligationCommand}" Content="Eliminar obligación" />
          </WrapPanel>
          <WrapPanel Visibility="{Binding IsPaymentMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Width="300" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Obligación" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding PaymentOptions}" SelectedItem="{Binding SelectedPaymentOption}" DisplayMemberPath="Display" /></StackPanel>
            <StackPanel Width="165" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de pago" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding PaymentDate}" /></StackPanel>
            <StackPanel Width="170" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Valor real pagado" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding PaymentAmountText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Width="320" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding PaymentDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <Button Margin="0,23,0,8" Style="{StaticResource ActionButton}" Command="{Binding RegisterPaymentCommand}" Content="Registrar pago" />
          </WrapPanel>
        </Grid>
      </Border>
    </StackPanel>
    <Grid Grid.Row="2" Margin="0,14,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
      <GroupBox Header="Obligaciones registradas" Padding="6">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding Obligations}" SelectedItem="{Binding SelectedObligation}">
          <DataGrid.Columns><DataGridTextColumn Width="180" Binding="{Binding Name}" Header="Nombre" /><DataGridTextColumn Width="120" Binding="{Binding Type}" Header="Tipo" /><DataGridTextColumn Width="120" Binding="{Binding Recurrence}" Header="Recurrencia" /><DataGridTextColumn Width="155" Binding="{Binding NextDueDate}" Header="Próximo vencimiento" /><DataGridTextColumn Width="145" Binding="{Binding ExpectedAmount}" Header="Valor esperado" /><DataGridTextColumn Width="260" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
        </DataGrid>
      </GroupBox>
      <GroupBox Grid.Column="2" Header="Pagos registrados" Padding="6">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding Payments}">
          <DataGrid.Columns><DataGridTextColumn Width="110" Binding="{Binding Date}" Header="Fecha del pago" /><DataGridTextColumn Width="190" Binding="{Binding Obligation}" Header="Obligación" /><DataGridTextColumn Width="150" Binding="{Binding CoveredDueDate}" Header="Vencimiento cubierto" /><DataGridTextColumn Width="145" Binding="{Binding ActualAmount}" Header="Valor real pagado" /><DataGridTextColumn Width="260" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
        </DataGrid>
      </GroupBox>
    </Grid>
    <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
  </Grid>
</UserControl>
