<UserControl x:Class="PeluqueriaAdmin.App.Views.ObligationsView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
 xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels" d:DataContext="{d:DesignInstance Type=viewModels:ObligationsViewModel, IsDesignTimeCreatable=False}"
 d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Margin" Value="0,0,0,5" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#273449" /><Setter Property="TextWrapping" Value="Wrap" /></Style>
    <Style x:Key="FieldBox" TargetType="Control"><Setter Property="MinHeight" Value="36" /><Setter Property="Padding" Value="9,6" /></Style>
    <Style x:Key="ActionButton" TargetType="Button"><Setter Property="Margin" Value="0,0,8,8" /><Setter Property="Padding" Value="12,7" /><Setter Property="Background" Value="#EEF2FF" /><Setter Property="BorderBrush" Value="#A5B4FC" /></Style>
  </UserControl.Resources>
  <Grid Margin="26" Background="#F5F7FA">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,12"><TextBlock FontSize="28" FontWeight="SemiBold" Text="Obligaciones" /><TextBlock Margin="0,5,0,0" Foreground="#5B6575" Text="Catálogo permanente y pagos reales vinculados a cada vencimiento." /></StackPanel>
    <StackPanel Grid.Row="1">
      <WrapPanel Margin="0,0,0,8"><Button Style="{StaticResource ActionButton}" Command="{Binding ShowAddModeCommand}" Content="Agregar obligación" /><Button Style="{StaticResource ActionButton}" Command="{Binding ShowPaymentModeCommand}" Content="Registrar pago" /><Button Style="{StaticResource ActionButton}" Command="{Binding ShowLoanModeCommand}" Content="Añadir préstamo" /></WrapPanel>
      <Border Padding="14" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
        <Grid>
          <WrapPanel Visibility="{Binding IsAddMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Width="210" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre de la obligación" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding NameText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Width="155" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Tipo" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding TypeOptions}" SelectedItem="{Binding SelectedType}" /></StackPanel>
            <StackPanel Width="155" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Recurrencia" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding RecurrenceOptions}" SelectedItem="{Binding SelectedRecurrence}" /></StackPanel>
            <StackPanel Width="165" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Vencimiento inicial" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding InitialDueDate}" /></StackPanel>
            <StackPanel Width="160" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Valor esperado fijo" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ExpectedAmountText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Width="300" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ObligationDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding AddObligationCommand}" Content="Agregar obligación" />
            <Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding EditSelectedObligationCommand}" Content="Editar obligación seleccionada" />
            <Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding SaveObligationEditCommand}" Content="Guardar edición" />
            <CheckBox Margin="8,31,8,0" IsChecked="{Binding ConfirmDelete}" Content="Confirmo eliminar" />
            <Button Margin="0,23,0,8" Style="{StaticResource ActionButton}" Command="{Binding DeleteSelectedObligationCommand}" Content="Eliminar obligación" />
          </WrapPanel>
          <WrapPanel Visibility="{Binding IsPaymentMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <StackPanel Width="300" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Obligación" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding PaymentOptions}" SelectedItem="{Binding SelectedPaymentOption}" DisplayMemberPath="Display" /></StackPanel>
            <StackPanel Width="165" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de pago" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding PaymentDate}" /></StackPanel>
            <StackPanel Width="170" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Valor real pagado" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding PaymentAmountText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <StackPanel Width="320" Margin="0,0,12,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding PaymentDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            <Button Margin="0,23,0,8" Style="{StaticResource ActionButton}" Command="{Binding RegisterPaymentCommand}" Content="Registrar pago" />
          </WrapPanel>
          <StackPanel Visibility="{Binding IsLoanMode, Converter={StaticResource BooleanToVisibilityConverter}}">
            <TextBlock Margin="0,0,0,8" FontSize="17" FontWeight="SemiBold" Text="Registrar préstamo recibido" />
            <WrapPanel>
              <StackPanel Width="200" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding LoanName, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="155" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Capital recibido" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding LoanInitialBalance, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="245" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Método de cálculo" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding LoanCalculationMethodOptions}" SelectedItem="{Binding SelectedLoanCalculationMethod}" /></StackPanel>
              <StackPanel Width="175" Margin="0,0,10,8" Visibility="{Binding ShowMonthlyInterest, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="Interés mensual (%)" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding LoanMonthlyInterestPercent, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="185" Margin="0,0,10,8" Visibility="{Binding ShowAgreedFinalAmount, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="Cantidad final acordada" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding LoanAgreedFinalAmount, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="155" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Cantidad de cuotas" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding LoanInstallmentCount, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="175" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Primera fecha de pago" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding LoanFirstDueDate}" /></StackPanel>
              <StackPanel Width="260" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding LoanDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <Button Margin="0,23,0,8" Style="{StaticResource ActionButton}" Command="{Binding AddLoanCommand}" Content="Registrar préstamo" />
            </WrapPanel>
            <TextBlock Margin="0,0,0,10" Padding="8" Background="#F8FAFC" Foreground="#334155"
                       Text="{Binding LoanPreview}" TextWrapping="Wrap" />
            <WrapPanel>
              <StackPanel Width="250" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Préstamo seleccionado" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding Loans}" SelectedItem="{Binding SelectedLoan}" DisplayMemberPath="Name" /></StackPanel>
              <StackPanel Width="145" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de pago" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding LoanPaymentDate}" /></StackPanel>
              <StackPanel Width="145" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Valor pagado" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding LoanPaymentAmount, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="260" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding LoanPaymentDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <Button Margin="0,23,0,8" Style="{StaticResource ActionButton}" Command="{Binding RegisterLoanPaymentCommand}" Content="Registrar cuota" />
            </WrapPanel>
          </StackPanel>
        </Grid>
      </Border>
    </StackPanel>
    <Grid Grid.Row="2" Margin="0,14,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
      <GroupBox Header="Obligaciones registradas" Padding="6">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding Obligations}" SelectedItem="{Binding SelectedObligation}">
          <DataGrid.Columns><DataGridTextColumn Width="180" Binding="{Binding Name}" Header="Nombre" /><DataGridTextColumn Width="120" Binding="{Binding Type}" Header="Tipo" /><DataGridTextColumn Width="120" Binding="{Binding Recurrence}" Header="Recurrencia" /><DataGridTextColumn Width="155" Binding="{Binding NextDueDate}" Header="Próximo vencimiento" /><DataGridTextColumn Width="145" Binding="{Binding ExpectedAmount}" Header="Valor esperado" /><DataGridTextColumn Width="260" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
        </DataGrid>
      </GroupBox>
      <GroupBox Grid.Column="2" Header="Pagos registrados" Padding="6">
        <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding Payments}">
          <DataGrid.Columns><DataGridTextColumn Width="110" Binding="{Binding Date}" Header="Fecha del pago" /><DataGridTextColumn Width="190" Binding="{Binding Obligation}" Header="Obligación" /><DataGridTextColumn Width="150" Binding="{Binding CoveredDueDate}" Header="Vencimiento cubierto" /><DataGridTextColumn Width="145" Binding="{Binding ActualAmount}" Header="Valor real pagado" /><DataGridTextColumn Width="260" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
        </DataGrid>
      </GroupBox>
    </Grid>
    <Grid Grid.Row="3" Margin="0,12,0,0" Visibility="{Binding IsLoanMode, Converter={StaticResource BooleanToVisibilityConverter}}">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /><ColumnDefinition Width="12" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
      <GroupBox Header="Préstamos"><DataGrid MaxHeight="230" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding Loans}" SelectedItem="{Binding SelectedLoan}"><DataGrid.Columns><DataGridTextColumn Width="170" Header="Nombre" Binding="{Binding Name}" /><DataGridTextColumn Width="220" Header="Método" Binding="{Binding Method}" /><DataGridTextColumn Width="125" Header="Capital" Binding="{Binding InitialBalance}" /><DataGridTextColumn Width="125" Header="Total acordado" Binding="{Binding ExpectedTotal}" /><DataGridTextColumn Width="125" Header="Interés total" Binding="{Binding TotalInterest}" /><DataGridTextColumn Width="125" Header="Saldo pendiente" Binding="{Binding PendingBalance}" /><DataGridTextColumn Width="120" Header="Cuota" Binding="{Binding Installment}" /><DataGridTextColumn Width="110" Header="Próximo pago" Binding="{Binding NextDueDate}" /><DataGridTextColumn Width="90" Header="Estado" Binding="{Binding State}" /></DataGrid.Columns></DataGrid></GroupBox>
      <GroupBox Grid.Column="2" Header="Calendario de cuotas"><DataGrid MaxHeight="230" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding LoanInstallments}"><DataGrid.Columns><DataGridTextColumn Width="160" Header="Préstamo" Binding="{Binding Loan}" /><DataGridTextColumn Width="65" Header="N.º" Binding="{Binding Number}" /><DataGridTextColumn Width="105" Header="Vence" Binding="{Binding DueDate}" /><DataGridTextColumn Width="120" Header="Cuota" Binding="{Binding Amount}" /><DataGridTextColumn Width="120" Header="Capital" Binding="{Binding Principal}" /><DataGridTextColumn Width="120" Header="Interés" Binding="{Binding Interest}" /><DataGridTextColumn Width="130" Header="Saldo capital" Binding="{Binding PrincipalBalance}" /><DataGridTextColumn Width="90" Header="Estado" Binding="{Binding State}" /></DataGrid.Columns></DataGrid></GroupBox>
      <GroupBox Grid.Column="4" Header="Pagos de préstamos"><DataGrid MaxHeight="230" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding LoanPayments}"><DataGrid.Columns><DataGridTextColumn Width="105" Header="Fecha" Binding="{Binding Date}" /><DataGridTextColumn Width="170" Header="Préstamo" Binding="{Binding Loan}" /><DataGridTextColumn Width="120" Header="Valor" Binding="{Binding Amount}" /><DataGridTextColumn Width="240" Header="Descripción" Binding="{Binding Description}" /></DataGrid.Columns></DataGrid></GroupBox>
    </Grid>
    <TextBlock Grid.Row="4" Margin="0,8,0,0" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
  </Grid>
</UserControl>
