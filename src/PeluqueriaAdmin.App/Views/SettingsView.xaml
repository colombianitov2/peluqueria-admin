<UserControl x:Class="PeluqueriaAdmin.App.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:SettingsViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="640"
             d:DesignWidth="784"
             Language="es-ES"
             mc:Ignorable="d">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid Margin="32" MaxWidth="640" HorizontalAlignment="Left">
      <Grid.Resources>
        <Style TargetType="TextBox">
          <Setter Property="Margin" Value="0,6,0,18" />
          <Setter Property="Padding" Value="10,7" />
          <Setter Property="MinWidth" Value="280" />
        </Style>
        <Style TargetType="TextBlock" x:Key="FieldLabel">
          <Setter Property="FontWeight" Value="SemiBold" />
        </Style>
      </Grid.Resources>

      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <StackPanel Grid.Row="0" Margin="0,0,0,24">
        <TextBlock FontSize="26" FontWeight="SemiBold" Text="Ajustes" />
        <TextBlock Margin="0,6,0,0"
                   Foreground="#4B5563"
                   Text="Los cambios válidos se guardan automáticamente. Si un valor está incompleto o no es válido, los campos escritos se conservan para continuar después."
                   TextWrapping="Wrap" />
      </StackPanel>

      <StackPanel Grid.Row="1">
        <TextBlock Style="{StaticResource FieldLabel}" Text="Valor semanal general por uso del local (USD)" />
        <TextBox MaxLength="18"
                 Text="{Binding WeeklyUsageFee, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Importe no negativo con máximo dos decimales." />
      </StackPanel>

      <StackPanel Grid.Row="2">
        <TextBlock Style="{StaticResource FieldLabel}" Text="Ganancia colaboradores (%)" />
        <TextBox MaxLength="7"
                 Text="{Binding CollaboratorProfitPercent, UpdateSourceTrigger=PropertyChanged}"
                 ToolTip="Porcentaje entre 0 y 100 con máximo dos decimales." />
      </StackPanel>

      <Border Grid.Row="4" Margin="0,4,0,24" Padding="18" Background="#FFF7ED" CornerRadius="6">
        <StackPanel>
          <TextBlock Margin="0,0,0,12" FontSize="20" FontWeight="SemiBold" Text="Gastos extraoficiales" />
          <TextBlock Margin="0,0,0,12"
                     Foreground="#4B5563"
                     Text="Se usan únicamente para el precio sugerido por silla y no forman parte del Balance anual oficial."
                     TextWrapping="Wrap" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" />
          <TextBox Text="{Binding UnofficialExpenseName, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="Valor mensual (USD)" />
          <TextBox Text="{Binding UnofficialExpenseAmount, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="Fecha desde la que aplica (AAAA-MM-DD)" />
          <TextBox Text="{Binding UnofficialExpenseEffectiveFrom, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" />
          <TextBox MinHeight="58"
                   AcceptsReturn="True"
                   Text="{Binding UnofficialExpenseDescription, UpdateSourceTrigger=PropertyChanged}"
                   TextWrapping="Wrap" />
          <WrapPanel Margin="0,0,0,12">
            <Button Margin="0,0,8,8" Padding="12,8" Command="{Binding AddUnofficialExpenseCommand}" Content="Agregar" />
            <Button Margin="0,0,8,8" Padding="12,8" Command="{Binding EditUnofficialExpenseCommand}" Content="Editar seleccionado" />
            <Button Margin="0,0,8,8" Padding="12,8" Command="{Binding SaveUnofficialExpenseEditCommand}" Content="Guardar edición" />
            <CheckBox Margin="4,0,8,8" VerticalAlignment="Center" IsChecked="{Binding ConfirmUnofficialExpenseDelete}" Content="Confirmo eliminar" />
            <Button Padding="12,8" Command="{Binding DeleteUnofficialExpenseCommand}" Content="Eliminar seleccionado" />
          </WrapPanel>
          <DataGrid MinHeight="150"
                    AutoGenerateColumns="False"
                    IsReadOnly="True"
                    ItemsSource="{Binding UnofficialExpenses}"
                    SelectedItem="{Binding SelectedUnofficialExpense}">
            <DataGrid.Columns>
              <DataGridTextColumn Width="110" Header="Desde" Binding="{Binding Date}" />
              <DataGridTextColumn Width="220" Header="Nombre" Binding="{Binding Principal}" />
              <DataGridTextColumn Width="140" Header="Valor mensual (USD)" Binding="{Binding Amount}" />
              <DataGridTextColumn Width="340" ElementStyle="{StaticResource WrappingCellText}" Header="Descripción" Binding="{Binding Detail}" />
            </DataGrid.Columns>
          </DataGrid>
        </StackPanel>
      </Border>

      <Border Grid.Row="5" Margin="0,12,0,24" Padding="18" Background="#F3F4F6" CornerRadius="6">
        <StackPanel>
          <TextBlock FontSize="20" FontWeight="SemiBold" Text="Datos" />
          <TextBlock Margin="0,5,0,14"
                     Foreground="#4B5563"
                     Text="Crea copias locales, restaura una copia compatible o exporta toda la información. Antes de restaurar se guarda automáticamente el estado actual."
                     TextWrapping="Wrap" />

          <WrapPanel Margin="0,0,0,10">
            <Button Margin="0,0,8,8" Padding="12,8" Command="{Binding CreateBackupCommand}" Content="Crear copia ahora" />
            <Button Margin="0,0,8,8" Padding="12,8" Command="{Binding OpenBackupsCommand}" Content="Abrir copias" />
          </WrapPanel>

          <Border Margin="0,2,0,16" Padding="14" Background="White" BorderBrush="#D8DEE9" BorderThickness="1" CornerRadius="5">
            <StackPanel>
              <TextBlock FontWeight="SemiBold" Text="Exportación completa a Excel" />
              <TextBlock Margin="0,4,0,10"
                         Foreground="#4B5563"
                         Text="Crea un único libro .xlsx con datos actuales, históricos, futuros, eliminados y borradores separados."
                         TextWrapping="Wrap" />
              <TextBlock FontWeight="SemiBold" Text="Carpeta de exportación" />
              <DockPanel Margin="0,5,0,10" LastChildFill="True">
                <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="12,7" Click="SelectExportFolder_Click" Content="Cambiar carpeta…" />
                <Button DockPanel.Dock="Right" Margin="8,0,0,0" Padding="12,7" Command="{Binding ResetExportDirectoryCommand}" Content="Restablecer al Escritorio" />
                <TextBox Margin="0" MinWidth="300" IsReadOnly="True" Text="{Binding ExportDirectory}" />
              </DockPanel>
              <WrapPanel>
                <Button Margin="0,0,8,8" Padding="12,8" Command="{Binding ExportAllToExcelCommand}" Content="Exportar toda la información a Excel" />
                <Button Margin="0,0,8,8" Padding="12,8" Command="{Binding OpenExcelFileCommand}" Content="Abrir archivo" />
                <Button Margin="0,0,0,8" Padding="12,8" Command="{Binding OpenExcelFolderCommand}" Content="Abrir carpeta" />
              </WrapPanel>
            </StackPanel>
          </Border>

          <TextBlock Style="{StaticResource FieldLabel}" Text="Archivo de copia para restaurar" />
          <DockPanel LastChildFill="True">
            <Button DockPanel.Dock="Right"
                    Margin="8,6,0,18"
                    Padding="12,7"
                    Click="SelectBackup_Click"
                    Content="Seleccionar…" />
            <TextBox Text="{Binding RestorePath, UpdateSourceTrigger=PropertyChanged}" />
          </DockPanel>
          <Button Width="150"
                  Padding="12,8"
                  HorizontalAlignment="Left"
                  Command="{Binding RestoreBackupCommand}"
                  Content="Restaurar copia" />
        </StackPanel>
      </Border>

      <Border Grid.Row="6" Margin="0,0,0,24" Padding="18" Background="#F3F4F6" CornerRadius="6">
        <StackPanel>
          <TextBlock FontSize="20" FontWeight="SemiBold" Text="Actualizaciones" />
          <TextBlock Margin="0,5,0,14"
                     Foreground="#4B5563"
                     Text="Busca y descarga versiones publicadas en GitHub. Instalar y reiniciar solo se habilita cuando la descarga terminó."
                     TextWrapping="Wrap" />
          <WrapPanel>
            <Button Margin="0,0,8,0"
                    Padding="12,8"
                    Command="{Binding CheckForUpdatesCommand}"
                    Content="Buscar actualización" />
            <Button Padding="12,8"
                    Command="{Binding ApplyUpdateCommand}"
                    Content="Instalar y reiniciar" />
          </WrapPanel>
        </StackPanel>
      </Border>

      <Border Grid.Row="7"
              Margin="0,2,0,18"
              Padding="12"
              Background="#E8EEF6"
              Visibility="{Binding HasStatusMessage, Converter={StaticResource BooleanToVisibilityConverter}}">
        <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap">
          <TextBlock.Style>
            <Style TargetType="TextBlock">
              <Setter Property="Foreground" Value="#166534" />
              <Style.Triggers>
                <DataTrigger Binding="{Binding IsError}" Value="True">
                  <Setter Property="Foreground" Value="#B91C1C" />
                </DataTrigger>
              </Style.Triggers>
            </Style>
          </TextBlock.Style>
        </TextBlock>
      </Border>

    </Grid>
  </ScrollViewer>
</UserControl>
