<UserControl x:Class="PeluqueriaAdmin.App.Views.CollaboratorsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels"
             d:DataContext="{d:DesignInstance Type=viewModels:CollaboratorsViewModel, IsDesignTimeCreatable=False}"
             d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources>
    <Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Margin" Value="0,0,0,5" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#273449" /></Style>
    <Style x:Key="FieldBox" TargetType="Control"><Setter Property="MinHeight" Value="36" /><Setter Property="Padding" Value="9,6" /></Style>
    <Style x:Key="ActionButton" TargetType="Button"><Setter Property="Margin" Value="0,0,8,8" /><Setter Property="Padding" Value="12,7" /><Setter Property="Background" Value="#EEF2FF" /><Setter Property="BorderBrush" Value="#A5B4FC" /></Style>
  </UserControl.Resources>
  <Grid Background="#F5F7FA">
    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <ScrollViewer.Style>
        <Style TargetType="ScrollViewer"><Setter Property="Visibility" Value="Visible" /><Style.Triggers><DataTrigger Binding="{Binding IsProfileOpen}" Value="True"><Setter Property="Visibility" Value="Collapsed" /></DataTrigger></Style.Triggers></Style>
      </ScrollViewer.Style>
      <StackPanel Margin="26">
        <DockPanel Margin="0,0,0,14">
          <StackPanel DockPanel.Dock="Right" MinWidth="190">
            <TextBlock HorizontalAlignment="Right" Style="{StaticResource FieldLabel}" Text="Periodo de actividad" />
            <ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" />
            <WrapPanel Margin="0,6,0,0" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}"><DatePicker Width="138" Margin="0,0,6,0" SelectedDate="{Binding CustomPeriodFrom}" /><DatePicker Width="138" SelectedDate="{Binding CustomPeriodThrough}" /></WrapPanel>
          </StackPanel>
          <StackPanel><TextBlock FontSize="28" FontWeight="SemiBold" Text="Colaboradores" /><TextBlock Margin="0,5,0,0" Foreground="#5B6575" Text="Inversionistas, aportes de capital y distribuciones; nunca ocupan sillas." /></StackPanel>
        </DockPanel>
        <TextBlock Margin="0,0,0,6" FontSize="16" FontWeight="SemiBold" Text="Actividad del periodo" />
        <Border Height="150" Margin="0,0,0,14" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ItemsSource="{Binding ActivityRows}">
            <DataGrid.Columns><DataGridTextColumn Width="105" Binding="{Binding Date}" Header="Fecha" /><DataGridTextColumn Width="180" Binding="{Binding Principal}" Header="Operación" /><DataGridTextColumn Width="3*" Binding="{Binding Detail}" Header="Descripción" /><DataGridTextColumn Width="180" Binding="{Binding Status}" Header="Actividad" /></DataGrid.Columns>
          </DataGrid>
        </Border>
        <Border Margin="0,0,0,16" Padding="16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <StackPanel>
            <DockPanel><Button DockPanel.Dock="Right" Style="{StaticResource ActionButton}" Command="{Binding ClearFormCommand}" Content="Limpiar formulario" /><TextBlock Margin="0,5,0,12" FontSize="18" FontWeight="SemiBold" Text="Añadir colaborador" /></DockPanel>
            <WrapPanel>
              <StackPanel Width="230" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding NewName, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="165" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de ingreso" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding NewStartDate}" /></StackPanel>
              <StackPanel Width="165" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha de retiro" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding NewExitDate}" /></StackPanel>
              <StackPanel Width="300" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding NewDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            </WrapPanel>
            <Button Width="165" HorizontalAlignment="Left" Style="{StaticResource ActionButton}" Command="{Binding AddCollaboratorCommand}" Content="Añadir colaborador" />
          </StackPanel>
        </Border>
        <TextBlock Margin="0,0,0,6" FontSize="18" FontWeight="SemiBold" Text="Colaboradores registrados" />
        <DockPanel Margin="0,0,0,8">
          <Button DockPanel.Dock="Right" Padding="12,5" Command="{Binding OpenSelectedProfileCommand}"
                  Content="Abrir perfil seleccionado" />
          <TextBlock VerticalAlignment="Center" Foreground="#5B6575"
                     Text="Haz doble clic para abrir el perfil y consultar aportes, cierres y distribuciones." />
        </DockPanel>
        <Border MinHeight="240" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <DataGrid AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" BorderThickness="0" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ItemsSource="{Binding Collaborators}" SelectedItem="{Binding SelectedCollaboratorRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" MouseDoubleClick="OnCollaboratorDoubleClick">
            <DataGrid.Columns><DataGridTextColumn Width="2*" Binding="{Binding Name}" Header="Nombre" /><DataGridTextColumn Width="120" Binding="{Binding StartDate}" Header="Ingreso" /><DataGridTextColumn Width="120" Binding="{Binding ExitDate}" Header="Retiro" /><DataGridTextColumn Width="100" Binding="{Binding State}" Header="Estado" /><DataGridTextColumn Width="3*" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
          </DataGrid>
        </Border>
        <TextBlock Margin="0,12,0,0" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </StackPanel>
    </ScrollViewer>

    <Grid Margin="26">
      <Grid.Style><Style TargetType="Grid"><Setter Property="Visibility" Value="Collapsed" /><Style.Triggers><DataTrigger Binding="{Binding IsProfileOpen}" Value="True"><Setter Property="Visibility" Value="Visible" /></DataTrigger></Style.Triggers></Style></Grid.Style>
      <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="150" /><RowDefinition Height="*" /></Grid.RowDefinitions>
      <StackPanel Grid.Row="0">
        <DockPanel Margin="0,0,0,10">
          <Button DockPanel.Dock="Right" Style="{StaticResource ActionButton}" Command="{Binding CloseProfileCommand}" Content="Cerrar perfil" />
          <StackPanel><TextBlock FontSize="26" FontWeight="SemiBold" Text="Perfil del colaborador" /><TextBlock Foreground="#5B6575" Text="Los datos existentes se autoguardan; los aportes requieren confirmación explícita." /></StackPanel>
        </DockPanel>
        <WrapPanel>
          <StackPanel Width="220" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Nombre" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
          <StackPanel Width="155" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Ingreso" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ProfileStartDate}" /></StackPanel>
          <StackPanel Width="155" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Retiro" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ProfileExitDate}" /></StackPanel>
          <StackPanel Width="300" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ProfileDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
        </WrapPanel>
        <WrapPanel>
          <StackPanel Width="150" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha del aporte" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ContributionDate}" /></StackPanel>
          <StackPanel Width="150" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Valor" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ContributionAmount, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
          <StackPanel Width="260" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ContributionDescription, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
          <Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding SaveContributionCommand}" Content="Añadir aporte" />
          <Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding EditSelectedContributionCommand}" Content="Editar aporte seleccionado" />
          <CheckBox Margin="8,31,8,0" IsChecked="{Binding ConfirmContributionDelete}" Content="Confirmo eliminar" />
          <Button Margin="0,23,0,8" Style="{StaticResource ActionButton}" Command="{Binding DeleteSelectedContributionCommand}" Content="Eliminar aporte" />
        </WrapPanel>
        <TextBlock Margin="0,0,0,6" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
      </StackPanel>
      <DataGrid Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ItemsSource="{Binding Contributions}" SelectedItem="{Binding SelectedContributionRow, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
        <DataGrid.Columns><DataGridTextColumn Width="110" Binding="{Binding Date}" Header="Fecha" /><DataGridTextColumn Width="150" Binding="{Binding Amount}" Header="Valor" /><DataGridTextColumn Width="3*" Binding="{Binding Description}" Header="Descripción" /><DataGridTextColumn Width="150" Binding="{Binding State}" Header="Clasificación" /></DataGrid.Columns>
      </DataGrid>
      <Grid Grid.Row="2" Margin="0,10,0,0">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <DockPanel Margin="0,0,0,6"><StackPanel DockPanel.Dock="Right" Orientation="Horizontal"><ComboBox Width="190" Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" /><DatePicker Width="135" Margin="8,0,0,0" SelectedDate="{Binding CustomPeriodFrom}" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}" /><DatePicker Width="135" Margin="8,0,0,0" SelectedDate="{Binding CustomPeriodThrough}" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}" /></StackPanel><TextBlock FontSize="18" FontWeight="SemiBold" Text="Historial cronológico" /></DockPanel>
        <DataGrid Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling" ScrollViewer.VerticalScrollBarVisibility="Auto" ItemsSource="{Binding HistoryRows}">
          <DataGrid.Columns><DataGridTextColumn Width="105" Binding="{Binding Date}" Header="Fecha" /><DataGridTextColumn Width="190" Binding="{Binding Principal}" Header="Operación" /><DataGridTextColumn Width="3*" Binding="{Binding Detail}" Header="Detalle" /><DataGridTextColumn Width="140" Binding="{Binding Amount}" Header="Valor" /><DataGridTextColumn Width="150" Binding="{Binding Status}" Header="Estado" /></DataGrid.Columns>
        </DataGrid>
      </Grid>
    </Grid>
  </Grid>
</UserControl>
