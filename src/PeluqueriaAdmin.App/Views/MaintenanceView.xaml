<UserControl x:Class="PeluqueriaAdmin.App.Views.MaintenanceView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels" d:DataContext="{d:DesignInstance Type=viewModels:MaintenanceViewModel, IsDesignTimeCreatable=False}" d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources><Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Margin" Value="0,0,0,5" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#273449" /></Style><Style x:Key="FieldBox" TargetType="Control"><Setter Property="MinHeight" Value="36" /><Setter Property="Padding" Value="9,6" /></Style><Style x:Key="ActionButton" TargetType="Button"><Setter Property="Margin" Value="0,0,8,8" /><Setter Property="Padding" Value="12,7" /><Setter Property="Background" Value="#EEF2FF" /><Setter Property="BorderBrush" Value="#A5B4FC" /></Style></UserControl.Resources>
  <Grid Background="#F5F7FA">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
    <ScrollViewer Grid.Row="0" MaxHeight="430" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="26,26,26,12">
        <DockPanel Margin="0,0,0,14"><StackPanel DockPanel.Dock="Right" MinWidth="190"><TextBlock HorizontalAlignment="Right" Style="{StaticResource FieldLabel}" Text="Periodo a mostrar" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" /><WrapPanel Margin="0,6,0,0" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}"><DatePicker Width="135" Margin="0,0,6,0" SelectedDate="{Binding CustomPeriodFrom}" /><DatePicker Width="135" SelectedDate="{Binding CustomPeriodThrough}" /></WrapPanel></StackPanel><StackPanel><TextBlock FontSize="28" FontWeight="SemiBold" Text="Mantenimiento" /><TextBlock Margin="0,5,0,0" Foreground="#5B6575" Text="Programa por activo y genera la siguiente ocurrencia solo al completar la actual." /></StackPanel></DockPanel>
        <Border Padding="16" Background="White" BorderBrush="#D7DEE8" BorderThickness="1" CornerRadius="7">
          <StackPanel><DockPanel Margin="0,0,0,10"><Button DockPanel.Dock="Right" Style="{StaticResource ActionButton}" Command="{Binding ClearFormCommand}" Content="Limpiar formulario" /><TextBlock FontSize="18" FontWeight="SemiBold" Text="Programar mantenimiento" /></DockPanel>
            <WrapPanel>
              <StackPanel Width="220" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Activo o equipo" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding AssetText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="210" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Tipo de mantenimiento" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding MaintenanceTypeText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="165" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha programada" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ScheduledDate}" /></StackPanel>
              <StackPanel Width="170" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Costo estimado" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding EstimatedCostText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="190" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Frecuencia" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding FrequencyOptions}" SelectedItem="{Binding SelectedFrequency}" /></StackPanel>
              <StackPanel Width="130" Margin="0,0,12,10" Visibility="{Binding ShowCustomInterval, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="Intervalo" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding CustomIntervalText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="150" Margin="0,0,12,10" Visibility="{Binding ShowCustomInterval, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="Unidad" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding CustomUnitOptions}" SelectedItem="{Binding SelectedCustomUnit}" /></StackPanel>
              <StackPanel Width="340" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            </WrapPanel>
            <WrapPanel><Button Style="{StaticResource ActionButton}" Command="{Binding ScheduleCommand}" Content="Programar mantenimiento" /><StackPanel Width="165" Margin="12,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha realizada" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding CompletedDate}" /></StackPanel><StackPanel Width="155" Margin="0,0,10,8"><TextBlock Style="{StaticResource FieldLabel}" Text="Costo real" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ActualCostText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel><Button Margin="0,23,8,8" Style="{StaticResource ActionButton}" Command="{Binding CompleteCommand}" Content="Marcar seleccionado como realizado" /><CheckBox Margin="8,31,8,0" IsChecked="{Binding ConfirmStop}" Content="Confirmo detener" /><Button Margin="0,23,0,8" Style="{StaticResource ActionButton}" Command="{Binding StopFutureCommand}" Content="Eliminar ocurrencia futura" /></WrapPanel>
            <TextBlock Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
          </StackPanel>
        </Border>
      </StackPanel>
    </ScrollViewer>
    <DataGrid Grid.Row="1" Margin="26,0,26,26" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding Records}" SelectedItem="{Binding SelectedRow}" EnableRowVirtualization="True" VirtualizingPanel.IsVirtualizing="True" VirtualizingPanel.VirtualizationMode="Recycling">
      <DataGrid.Columns><DataGridTextColumn Width="2*" Binding="{Binding Asset}" Header="Activo" /><DataGridTextColumn Width="180" Binding="{Binding Type}" Header="Tipo" /><DataGridTextColumn Width="115" Binding="{Binding ScheduledDate}" Header="Programado" /><DataGridTextColumn Width="150" Binding="{Binding Frequency}" Header="Frecuencia" /><DataGridTextColumn Width="140" Binding="{Binding EstimatedCost}" Header="Costo estimado" /><DataGridTextColumn Width="115" Binding="{Binding CompletedDate}" Header="Realizado" /><DataGridTextColumn Width="130" Binding="{Binding ActualCost}" Header="Costo real" /><DataGridTextColumn Width="100" Binding="{Binding State}" Header="Estado" /><DataGridTextColumn Width="3*" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
    </DataGrid>
  </Grid>
</UserControl>
