<UserControl x:Class="PeluqueriaAdmin.App.Views.MaintenanceView" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels" d:DataContext="{d:DesignInstance Type=viewModels:MaintenanceViewModel, IsDesignTimeCreatable=False}" d:DesignHeight="760" d:DesignWidth="990" Language="es-ES" mc:Ignorable="d">
  <UserControl.Resources><Style x:Key="FieldLabel" TargetType="TextBlock"><Setter Property="Margin" Value="0,0,0,5" /><Setter Property="FontWeight" Value="SemiBold" /><Setter Property="Foreground" Value="#273449" /></Style><Style x:Key="FieldBox" TargetType="Control"><Setter Property="MinHeight" Value="36" /><Setter Property="Padding" Value="9,6" /></Style><Style x:Key="ActionButton" TargetType="Button"><Setter Property="Margin" Value="0,0,8,8" /><Setter Property="Padding" Value="12,7" /><Setter Property="Background" Value="#EEF2FF" /><Setter Property="BorderBrush" Value="#A5B4FC" /></Style></UserControl.Resources>
  <Grid Margin="26" Background="#F5F7FA">
    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /><RowDefinition Height="Auto" /></Grid.RowDefinitions>
    <StackPanel Margin="0,0,0,12"><TextBlock FontSize="28" FontWeight="SemiBold" Text="Mantenimiento" /><TextBlock Margin="0,5,0,0" Foreground="#5B6575" Text="Programación y realización separadas; la recurrencia conserva su fecha original." /></StackPanel>
    <ScrollViewer Grid.Row="1" MaxHeight="330" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
      <Grid>
        <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
        <GroupBox Header="Programar mantenimiento" Padding="12">
          <StackPanel>
            <WrapPanel>
              <StackPanel Width="220" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Activo o equipo" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding AssetText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="210" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Tipo de mantenimiento" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding MaintenanceTypeText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="165" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha programada" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding ScheduledDate}" /></StackPanel>
              <StackPanel Width="165" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Costo estimado" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding EstimatedCostText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="190" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Frecuencia" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding FrequencyOptions}" SelectedItem="{Binding SelectedFrequency}" /></StackPanel>
              <StackPanel Width="130" Margin="0,0,12,10" Visibility="{Binding ShowCustomInterval, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="Intervalo" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding CustomIntervalText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
              <StackPanel Width="150" Margin="0,0,12,10" Visibility="{Binding ShowCustomInterval, Converter={StaticResource BooleanToVisibilityConverter}}"><TextBlock Style="{StaticResource FieldLabel}" Text="Unidad" /><ComboBox Style="{StaticResource FieldBox}" ItemsSource="{Binding CustomUnitOptions}" SelectedItem="{Binding SelectedCustomUnit}" /></StackPanel>
              <StackPanel Width="330" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Descripción opcional" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding DescriptionText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel>
            </WrapPanel>
            <WrapPanel><Button Style="{StaticResource ActionButton}" Command="{Binding ScheduleCommand}" Content="Programar mantenimiento" /><Button Style="{StaticResource ActionButton}" Command="{Binding SavePendingEditCommand}" Content="Guardar edición pendiente" /></WrapPanel>
          </StackPanel>
        </GroupBox>
        <GroupBox Grid.Column="2" Header="Completar mantenimiento" Padding="12">
          <StackPanel>
            <TextBlock Style="{StaticResource FieldLabel}" Text="Mantenimiento pendiente" />
            <ComboBox Margin="0,0,0,10" Style="{StaticResource FieldBox}" ItemsSource="{Binding PendingCompletionOptions}" SelectedItem="{Binding SelectedPendingToComplete}" DisplayMemberPath="CompletionDisplay" />
            <WrapPanel><StackPanel Width="165" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Fecha realizada" /><DatePicker Style="{StaticResource FieldBox}" SelectedDate="{Binding CompletedDate}" /></StackPanel><StackPanel Width="165" Margin="0,0,12,10"><TextBlock Style="{StaticResource FieldLabel}" Text="Costo real" /><TextBox Style="{StaticResource FieldBox}" Text="{Binding ActualCostText, UpdateSourceTrigger=PropertyChanged}" /></StackPanel></WrapPanel>
            <Button HorizontalAlignment="Left" Style="{StaticResource ActionButton}" Command="{Binding CompleteCommand}" Content="Marcar como realizado" />
          </StackPanel>
        </GroupBox>
      </Grid>
    </ScrollViewer>
    <Grid Grid.Row="2" Margin="0,14,0,0">
      <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="14" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
      <GroupBox Header="Equipos para mantenimiento" Padding="6">
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
          <WrapPanel Margin="0,0,0,6"><Button Style="{StaticResource ActionButton}" Command="{Binding EditSelectedPendingCommand}" Content="Editar pendiente" /><CheckBox Margin="8,8,8,0" IsChecked="{Binding ConfirmStop}" Content="Confirmo eliminar ocurrencia futura" /><Button Style="{StaticResource ActionButton}" Command="{Binding StopFutureCommand}" Content="Eliminar ocurrencia" /></WrapPanel>
          <DataGrid Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding PendingRecords}" SelectedItem="{Binding SelectedRow}">
            <DataGrid.Columns><DataGridTextColumn Width="190" Binding="{Binding Asset}" Header="Equipo" /><DataGridTextColumn Width="180" Binding="{Binding Type}" Header="Tipo" /><DataGridTextColumn Width="115" Binding="{Binding ScheduledDate}" Header="Fecha" /><DataGridTextColumn Width="145" Binding="{Binding Frequency}" Header="Frecuencia" /><DataGridTextColumn Width="145" Binding="{Binding EstimatedCost}" Header="Costo estimado" /><DataGridTextColumn Width="100" Binding="{Binding State}" Header="Estado" /><DataGridTextColumn Width="280" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Description}" Header="Descripción" /></DataGrid.Columns>
          </DataGrid>
        </Grid>
      </GroupBox>
      <GroupBox Grid.Column="2" Header="Historial de mantenimiento de equipos" Padding="6">
        <Grid><Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
          <WrapPanel HorizontalAlignment="Right" Margin="0,0,0,6"><ComboBox Width="240" Style="{StaticResource FieldBox}" ItemsSource="{Binding HistoryAssetOptions}" SelectedItem="{Binding SelectedHistoryAsset}" /><ComboBox Width="170" Margin="8,0,0,0" Style="{StaticResource FieldBox}" ItemsSource="{Binding PeriodOptions}" SelectedItem="{Binding SelectedPeriod}" /><DatePicker Width="135" Margin="8,0,0,0" SelectedDate="{Binding CustomPeriodFrom}" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}" /><DatePicker Width="135" Margin="8,0,0,0" SelectedDate="{Binding CustomPeriodThrough}" Visibility="{Binding ShowCustomPeriod, Converter={StaticResource BooleanToVisibilityConverter}}" /></WrapPanel>
          <DataGrid Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" IsReadOnly="True" ItemsSource="{Binding HistoryRecords}">
            <DataGrid.Columns><DataGridTextColumn Width="190" Binding="{Binding Asset}" Header="Equipo" /><DataGridTextColumn Width="180" Binding="{Binding Type}" Header="Tipo" /><DataGridTextColumn Width="120" Binding="{Binding ScheduledDate}" Header="Programada" /><DataGridTextColumn Width="120" Binding="{Binding CompletedDate}" Header="Realizada" /><DataGridTextColumn Width="145" Binding="{Binding EstimatedCost}" Header="Costo estimado" /><DataGridTextColumn Width="135" Binding="{Binding ActualCost}" Header="Costo real" /><DataGridTextColumn Width="280" ElementStyle="{StaticResource WrappingCellText}" Binding="{Binding Description}" Header="Descripción" /><DataGridTextColumn Width="100" Binding="{Binding State}" Header="Estado" /></DataGrid.Columns>
          </DataGrid>
        </Grid>
      </GroupBox>
    </Grid>
    <TextBlock Grid.Row="3" Margin="0,8,0,0" Foreground="#0F766E" Text="{Binding StatusMessage}" TextWrapping="Wrap" />
  </Grid>
</UserControl>
