<Window x:Class="PeluqueriaAdmin.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PeluqueriaAdmin.App.Views"
        xmlns:viewModels="clr-namespace:PeluqueriaAdmin.App.ViewModels"
        Title="Peluquería Admin"
        Width="1220"
        Height="760"
        MinWidth="860"
        MinHeight="520"
        Closing="OnClosing"
        WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <DataTemplate DataType="{x:Type viewModels:MainViewModel}">
      <views:HomeView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
      <views:SettingsView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:AdministrationViewModel}">
      <views:AdministrationView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:LocalUseViewModel}">
      <views:LocalUseView />
    </DataTemplate>
    <DataTemplate DataType="{x:Type viewModels:CollaboratorsViewModel}">
      <views:CollaboratorsView />
    </DataTemplate>
  </Window.Resources>
  <DockPanel>
    <Border DockPanel.Dock="Left"
            Width="230"
            Padding="14,20"
            Background="#172033">
      <DockPanel>
        <TextBlock DockPanel.Dock="Top"
                   Margin="8,0,8,22"
                   Foreground="White"
                   FontSize="18"
                   FontWeight="SemiBold"
                   Text="Peluquería Admin"
                   TextWrapping="Wrap" />
        <ListBox ItemsSource="{Binding NavigationItems}"
                 SelectedItem="{Binding SelectedNavigationItem, Mode=TwoWay}"
                 Background="Transparent"
                 BorderThickness="0"
                 ScrollViewer.VerticalScrollBarVisibility="Auto">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Margin" Value="0,0,0,6" />
              <Setter Property="Padding" Value="12,9" />
              <Setter Property="Foreground" Value="#DCE5F5" />
              <Setter Property="Background" Value="Transparent" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Cursor" Value="Hand" />
              <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                  <Setter Property="Background" Value="#2E5BFF" />
                  <Setter Property="Foreground" Value="White" />
                </Trigger>
                <Trigger Property="IsMouseOver" Value="True">
                  <Setter Property="Background" Value="#263451" />
                </Trigger>
              </Style.Triggers>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate>
              <TextBlock Text="{Binding Name}" TextWrapping="Wrap" />
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <ContentControl Content="{Binding CurrentPage}" Background="#F5F7FA" />
  </DockPanel>
</Window>
