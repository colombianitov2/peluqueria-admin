# Normalización de texto para evitar diferencias de finales de línea.
* text=auto
.gitattributes text eol=lf
.gitignore text eol=lf
LICENSE text eol=lf

# Código y archivos de proyecto
*.cs text eol=lf
*.xaml text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.sln text eol=crlf

# Documentación y configuración
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.ps1 text eol=crlf

# Archivos binarios
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.7z binary
*.dll binary
*.exe binary
*.db binary
*.sqlite binary
*.sqlite3 binary
